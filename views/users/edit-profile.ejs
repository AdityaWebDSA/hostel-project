<% layout("/layouts/boilerplate")%>
<link rel="stylesheet" href="/css/new-ejs.css">
<link rel="stylesheet" href="/css/profile.css">

<div class="row mt-4 mb-5">
    <div class="col-8 offset-2">
        <h3 class="page-heading">Edit Profile</h3>

        <div class="form-container">
            <form action="/profile?_method=PUT" method="POST" enctype="multipart/form-data" class="needs-validation" novalidate>

              <div class="mb-4 text-center">
                    <div class="profile-avatar-lg mx-auto mb-3" id="avatarPreviewWrap">
                        <% if (user.avatar && user.avatar.url) { %>
                            <img src="<%= user.avatar.url %>" id="avatarPreview" alt="">
                        <% } else { %>
                            <span id="avatarPreview"><%= user.username.charAt(0).toUpperCase() %></span>
                        <% } %>
                    </div>
                    <label for="avatarInput" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                        <i class="fa-solid fa-camera me-1"></i> Change Photo
                    </label>
                    <!-- This input is for selecting a file only — never submitted directly -->
                    <input type="file" id="avatarInput" accept="image/png, image/jpeg" class="d-none">
                    <!-- This hidden input holds the CROPPED result and is what actually submits -->
                    <input type="file" name="user[avatar]" id="avatarCroppedFile" class="d-none">
                    <small class="text-muted d-block mt-2">JPG or PNG, 5 MB max.</small>
                    <div id="avatarUploadError" class="upload-error-box mt-2" style="max-width:320px; margin:0 auto;"></div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Username</label>
                    <input type="text" class="form-control custom-input" value="<%= user.username %>" disabled>
                    <small class="text-muted">Username can't be changed.</small>
                </div>

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="text" class="form-control custom-input" value="<%= user.email %>" disabled>
                </div>

                <div class="mb-3">
                    <label for="phone" class="form-label">Phone Number</label>
                    <input type="tel" name="user[phone]" class="form-control custom-input" value="<%= user.phone || '' %>" placeholder="e.g., 9876543210">
                </div>

                <div class="mb-3">
                    <label for="bio" class="form-label">Bio</label>
                    <textarea name="user[bio]" class="form-control custom-input" rows="4" maxlength="300" placeholder="Tell others a bit about yourself..."><%= user.bio || '' %></textarea>
                    <small class="text-muted">Max 300 characters.</small>
                </div>

                <div class="d-grid gap-2 d-md-flex justify-content-md-start mt-4">
                    <button class="btn add-btn px-5 py-2" data-loading-text="Saving...">Save Changes</button>
                    <a href="/profile" class="btn btn-outline-secondary px-4 py-2">Cancel</a>
                </div>

                <!-- Avatar Crop Modal -->
<div id="avatarCropModal" class="avatar-crop-modal">
    <div class="avatar-crop-dialog">
        <h5 class="avatar-crop-title">Adjust your photo</h5>
        <p class="avatar-crop-hint">Drag to reposition &middot; Scroll or use the slider to zoom</p>

        <div class="avatar-crop-canvas-wrap">
            <canvas id="avatarCropCanvas"></canvas>
        </div>

        <div class="avatar-zoom-row">
            <i class="fa-solid fa-magnifying-glass-minus"></i>
            <input type="range" id="avatarZoomSlider" min="0" max="100" value="0">
            <i class="fa-solid fa-magnifying-glass-plus"></i>
        </div>

        <div class="avatar-crop-actions">
            <button type="button" class="btn btn-outline-secondary rounded-pill px-4" onclick="cancelAvatarCrop()">Cancel</button>
            <button type="button" class="btn btn-teal-solid rounded-pill px-4" onclick="confirmAvatarCrop()">
                <i class="fa-solid fa-check me-1"></i> Save Photo
            </button>
        </div>
    </div>
</div>
            </form>
        </div>
    </div>
</div>

