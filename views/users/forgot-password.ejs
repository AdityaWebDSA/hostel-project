<% layout("/layouts/boilerplate") %>
<link rel="stylesheet" href="/css/auth.css">

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-header">
            <div class="auth-logo">
                <img src="/ui_material/main_logo.png" alt="UniNest">
            </div>
            <h2>Forgot password?</h2>
            <p>Enter your email and we'll send you a reset link.</p>
        </div>

        <form action="/forgot-password" method="POST" class="needs-validation" novalidate>
            <div class="mb-4">
                <label for="email" class="form-label">Email address</label>
                <div class="input-group-custom">
                    <i class="fa-solid fa-envelope"></i>
                    <input name="email" id="email" placeholder="your@email.com"
                        type="email" class="form-control custom-input" required>
                </div>
                <div class="invalid-feedback">Please enter your email address</div>
            </div>

            <button type="submit" class="btn auth-btn w-100"
                data-loading-text="Sending...">
                Send Reset Link
            </button>
        </form>

        <div class="auth-footer">
            <p>Remember your password? <a href="/login">Log in</a></p>
        </div>
    </div>
</div>