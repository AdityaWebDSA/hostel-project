<% layout("/layouts/boilerplate") %>
<link rel="stylesheet" href="/css/error-page.css">

<div class="error-page-wrapper">
    <div class="error-card">
        <div class="error-icon-wrap <%= statusCode >= 500 ? 'server-error' : 'client-error' %>">
            <% if (statusCode === 404) { %>
                <i class="fa-solid fa-compass-drafting"></i>
            <% } else if (statusCode === 403) { %>
                <i class="fa-solid fa-lock"></i>
            <% } else { %>
                <i class="fa-solid fa-triangle-exclamation"></i>
            <% } %>
        </div>

        <div class="error-code"><%= statusCode %></div>

        <h2 class="error-title">
            <% if (statusCode === 404) { %>
                Page not found
            <% } else if (statusCode === 403) { %>
                Access denied
            <% } else if (statusCode === 401) { %>
                Login required
            <% } else { %>
                Something went wrong
            <% } %>
        </h2>

        <p class="error-message"><%= message %></p>

        <div class="error-actions">
            <a href="/listings" class="btn error-btn-primary">
                <i class="fa-solid fa-house me-2"></i>Go to Homepage
            </a>
            <button onclick="history.back()" class="btn error-btn-secondary">
                <i class="fa-solid fa-arrow-left me-2"></i>Go Back
            </button>
        </div>
    </div>
</div>