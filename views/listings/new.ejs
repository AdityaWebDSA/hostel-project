<% layout("/layouts/boilerplate") %>
<link rel="stylesheet" href="/css/new-ejs.css">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<div class="row mt-4 mb-5">
    <div class="col-8 offset-2">
        <h3 class="page-heading">Create a New Listing</h3>
        
        <div class="form-container">
            <form method="POST" action="/listings" class="needs-validation" novalidate enctype="multipart/form-data">

                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <input name="listing[title]" placeholder="Enter a catchy title" type="text" class="form-control custom-input" required> 
                    <div class="valid-feedback">Title looks good!</div>
                    <div class="invalid-feedback">Title is Required</div>
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea name="listing[description]" placeholder="Describe the place, rules, and amenities..." class="form-control custom-input" rows="4" required></textarea>
                    <div class="invalid-feedback">Please enter a short description</div>
                </div>

                <div class="mb-3 category-group">
                    <label class="form-label">What does this place offer? <span class="text-muted small">(select all that apply)</span></label>
                    <div class="category-grid">
                        <% CATEGORIES.forEach(cat => { %>
                            <div class="category-option">
                                <input type="checkbox" name="listing[category][]" value="<%= cat.key %>" id="cat-<%= cat.key %>" class="category-checkbox">
                                <label for="cat-<%= cat.key %>" class="category-label">
                                    <i class="<%= cat.icon %>"></i>
                                    <span><%= cat.label %></span>
                                </label>
                            </div>
                        <% }) %>
                    </div>
                    <input type="text" class="form-control category-validity" required>
                    <div class="invalid-feedback">Please select at least one category</div>
                </div>

                <div class="mb-3 billing-group" id="billingPlansSection">
                    <label class="form-label">Accepted Billing Plans <span class="text-muted small">(auto-suggested based on categories)</span></label>
                    <div class="billing-grid" id="billingGrid">
                        <% BILLING_PLANS.forEach(plan => { %>
                            <div class="billing-option">
                                <input type="checkbox" name="listing[billingPlans][]" value="<%= plan.key %>" id="plan-<%= plan.key %>" class="billing-checkbox"
                                    <%= plan.key === 'monthly' ? 'checked' : '' %>>
                                <label for="plan-<%= plan.key %>" class="billing-label">
                                    <i class="fa-solid fa-calendar-check"></i>
                                    <span><%= plan.label %></span>
                                </label>
                            </div>
                        <% }) %>
                    </div>
                    <input type="text" class="form-control billing-validity" required>
                    <div class="invalid-feedback">Please select at least one billing plan</div>
                    <small class="text-muted mt-1 d-block">Tip: selecting categories above will auto-suggest the right plans.</small>
                </div>

                <div class="mb-3">
                    <label for="image" class="form-label">Upload Listing Image</label>
                    <input name="listing[image]" type="file" class="form-control custom-input" multiple required>
                    <div class="invalid-feedback">A listing needs a photo!</div>
                </div>

                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="price" class="form-label">Price (₹)</label>
                        <input name="listing[price]" placeholder="1200" type="number" class="form-control custom-input" required>
                        <div class="invalid-feedback">Price should be valid</div>
                    </div>
                    
                    <div class="mb-3 col-md-8">
                        <label for="country" class="form-label">Country</label>
                        <input name="listing[country]" placeholder="India" type="text" class="form-control custom-input" required>
                        <div class="invalid-feedback">Country name should be valid</div>
                    </div>
                </div>

                <div class="mb-3">
                    <label for="landmark" class="form-label">Exact Landmark / Street</label>
                    <input name="listing[landmark]" placeholder="e.g., Near Bharati Vidyapeeth College" type="text" class="form-control custom-input">
                </div>

                <div class="mb-3">
                    <label for="location" class="form-label">City/Location</label>
                    <input name="listing[location]" id="locationInput" placeholder="Kolhapur, Maharashtra" type="text" class="form-control custom-input" required>
                    <div class="invalid-feedback">Location should be valid</div>
                </div>

                <div class="mb-4">
                    <label class="form-label">Pin the Exact Location <span class="text-muted small">(click or drag the marker)</span></label>
                    <div class="map-picker-wrapper">
                        <div id="locationPickerMap"></div>
                        <button type="button" id="locateMeBtn" class="locate-me-btn" title="Find my current location">
                            <i class="fa-solid fa-location-crosshairs"></i>
                        </button>
                    </div>
                    <small class="text-muted mt-1 d-block" id="pinStatusText">Type a city above, or click on the map to drop a pin.</small>
                    <input type="hidden" name="listing[lat]" id="latInput">
                    <input type="hidden" name="listing[lng]" id="lngInput">
                </div>

                <div class="row">
                    <div class="mb-3 col-md-6">
                        <label for="contactNumber" class="form-label">Contact Number</label>
                        <input name="listing[contactNumber]" placeholder="e.g., 9876543210" type="tel" class="form-control custom-input" pattern="[0-9+\-\s]{7,15}">
                        <div class="invalid-feedback">Enter a valid phone number (7-15 digits)</div>
                        <small class="text-muted">Shown to visitors so they can contact you directly.</small>
                    </div>
                    <div class="mb-3 col-md-6">
                        <label for="contactEmail" class="form-label">Contact Email</label>
                        <input name="listing[contactEmail]" placeholder="owner@example.com" type="email" class="form-control custom-input">
                        <div class="invalid-feedback">Enter a valid email address</div>
                    </div>
                </div>
                <div class="d-grid gap-2 d-md-flex justify-content-md-start mt-4">
                    <button class="btn add-btn px-5 py-2">Create Listing</button>
                    <a href="/listings" class="btn btn-outline-secondary px-4 py-2">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="/js/location-picker.js"></script>