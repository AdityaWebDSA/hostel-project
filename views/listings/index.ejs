<% layout("/layouts/boilerplate")%>
<link rel="stylesheet" href="/css/index-ejs.css">
<%
  // Helper to build a query string that preserves existing filters while changing one param
  function buildUrl(overrides) {
    const params = new URLSearchParams();
    if (typeof currentCategory !== 'undefined' && currentCategory) params.set('category', currentCategory);
    if (typeof searchQuery !== 'undefined' && searchQuery) params.set('q', searchQuery);
    if (typeof minPrice !== 'undefined' && minPrice) params.set('minPrice', minPrice);
    if (typeof maxPrice !== 'undefined' && maxPrice) params.set('maxPrice', maxPrice);
if (typeof currentSort !== 'undefined' && currentSort) params.set('sort', currentSort);
    if (typeof currentGender !== 'undefined' && currentGender) params.set('gender', currentGender);
    if (typeof currentPage !== 'undefined' && currentPage > 1) params.set('page', currentPage);

    Object.keys(overrides).forEach(key => {
      if (overrides[key] === null || overrides[key] === '') {
        params.delete(key);
      } else {
        params.set(key, overrides[key]);
      }
    });

    const base = (typeof searchQuery !== 'undefined' && searchQuery) ? '/listings/search' : '/listings';
    const qs = params.toString();
    return qs ? `${base}?${qs}` : base;
  }

  const sortLabels = {
    recommended: "Recommended",
    price_asc: "Price: Low to High",
    price_desc: "Price: High to Low",
    rating_desc: "Top Rated",
    newest: "Newest First",
  };
  const activeSort = (typeof currentSort !== 'undefined' && currentSort) ? currentSort : "recommended";
%>

<div class="index-container">
<div class="filters-wrapper">
        <button class="filter-arrow filter-arrow-left" id="filterLeft" aria-label="Scroll left">
            <i class="fa-solid fa-chevron-left"></i>
        </button>

        <div id="filters">
            <a href="<%= buildUrl({ category: null, page: null }) %>" class="filter <%= !currentCategory ? 'active' : '' %>">
                <i class="fa-solid fa-layer-group"></i>
                <p>All</p>
            </a>
            <% CATEGORIES.forEach(cat => { %>
                <a href="<%= buildUrl({ category: cat.key, page: null }) %>" class="filter <%= currentCategory === cat.key ? 'active' : '' %>">
                    <i class="<%= cat.icon %>"></i>
                    <p><%= cat.label %></p>
                </a>
            <% }) %>
        </div>

        <button class="filter-arrow filter-arrow-right" id="filterRight" aria-label="Scroll right">
            <i class="fa-solid fa-chevron-right"></i>
        </button>
    </div>
<!-- Location search map panel - shown when searching or using "Near Me" -->
    <div id="searchMapPanel" class="search-map-panel" style="display:none;">
        <div class="search-map-header">
            <div id="searchMapLabel" class="search-map-label">
                <i class="fa-solid fa-location-dot"></i>
                <span id="searchMapTitle">Nearby listings</span>
            </div>
            <button type="button" id="closeMapPanel" class="search-map-close">
                <i class="fa-solid fa-xmark"></i> Close map
            </button>
        </div>
        <div class="search-map-body">
            <div id="searchMap" class="search-map-leaflet"></div>
            <div id="searchMapSidebar" class="search-map-sidebar">
                <div id="searchMapResults" class="search-map-results">
                    <div class="search-map-loading">
                        <i class="fa-solid fa-spinner fa-spin"></i> Finding nearby places...
                    </div>
                </div>
            </div>
        </div>
    </div>
    <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
        <div class="search-results-banner mb-3">
            <i class="fa-solid fa-magnifying-glass"></i>
            Showing results for "<%= searchQuery %>"
            <% if (searchCenter) { %><span class="text-muted">— including nearby places</span><% } %>
            <a href="/listings" class="ms-2 clear-filter-link"><i class="fa-solid fa-xmark"></i> Clear</a>
        </div>
    <% } %>
<div class="near-me-bar mb-3">
        <button id="nearMeBtn" type="button" class="btn near-me-btn">
            <i class="fa-solid fa-location-crosshairs"></i>
            <span>Show listings near me</span>
        </button>
        <span id="nearMeStatus" class="near-me-status"></span>
    </div>
    <div class="result-info d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3 px-1">
        <h6 class="text-muted fw-normal mb-0">
            Showing <%= allListings.length %> available place<%= allListings.length === 1 ? '' : 's' %>
            <% if (currentCategory) {
                const activeCat = CATEGORIES.find(c => c.key === currentCategory);
            %>
                for "<%= activeCat ? activeCat.label : currentCategory %>"
            <% } %>
            <% if (currentCategory || minPrice || maxPrice) { %>
                <a href="<%= (typeof searchQuery !== 'undefined' && searchQuery) ? '/listings/search?q=' + encodeURIComponent(searchQuery) : '/listings' %>" class="ms-2 clear-filter-link"><i class="fa-solid fa-xmark"></i> Clear filters</a>
            <% } %>
        </h6>

        <div class="d-flex align-items-center gap-2">
            <form method="GET" action="<%= (typeof searchQuery !== 'undefined' && searchQuery) ? '/listings/search' : '/listings' %>" class="price-range-form d-flex align-items-center gap-1">
                <% if (typeof searchQuery !== 'undefined' && searchQuery) { %><input type="hidden" name="q" value="<%= searchQuery %>"><% } %>
                <% if (currentCategory) { %><input type="hidden" name="category" value="<%= currentCategory %>"><% } %>
                <% if (currentSort) { %><input type="hidden" name="sort" value="<%= currentSort %>"><% } %>
                <input type="number" name="minPrice" value="<%= minPrice %>" placeholder="Min ₹" class="price-input" min="0">
                <span class="text-muted small">–</span>
                <input type="number" name="maxPrice" value="<%= maxPrice %>" placeholder="Max ₹" class="price-input" min="0">
                <button type="submit" class="btn btn-sm price-apply-btn">Go</button>
            </form>

            <div class="dropdown">
                <button class="btn btn-sm btn-outline-secondary dropdown-toggle rounded-pill px-3" type="button" data-bs-toggle="dropdown">
                    Sort by: <%= sortLabels[activeSort] %>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <% Object.keys(sortLabels).forEach(key => { %>
                        <li><a class="dropdown-item <%= activeSort === key ? 'active' : '' %>" href="<%= buildUrl({ sort: key === 'recommended' ? null : key, page: null }) %>"><%= sortLabels[key] %></a></li>
                    <% }) %>
                </ul>
            </div>
        </div>
    </div>
<!-- Gender filter pills -->
    <div class="gender-filter-bar mb-2">
        <span class="gender-filter-label">Filter:</span>
        <a href="<%= buildUrl({ gender: null, page: null }) %>" class="gender-pill <%= !currentGender ? 'active' : '' %>">
            All
        </a>
        <a href="<%= buildUrl({ gender: 'boys', page: null }) %>" class="gender-pill boys <%= currentGender === 'boys' ? 'active' : '' %>">
            <i class="fa-solid fa-mars"></i> Boys
        </a>
        <a href="<%= buildUrl({ gender: 'girls', page: null }) %>" class="gender-pill girls <%= currentGender === 'girls' ? 'active' : '' %>">
            <i class="fa-solid fa-venus"></i> Girls
        </a>
        <a href="<%= buildUrl({ gender: 'coed', page: null }) %>" class="gender-pill coed <%= currentGender === 'coed' ? 'active' : '' %>">
            <i class="fa-solid fa-venus-mars"></i> Co-ed
        </a>
    </div>
   <% if (allListings.length === 0) { %>
        <div class="no-results-page">
            <div class="no-results-hero">
                <i class="fa-solid fa-map-location-dot"></i>
                <h4>
                    <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
                        No results for "<%= searchQuery %>"
                    <% } else { %>
                        No listings match these filters
                    <% } %>
                </h4>
                <p>
                    <% if (currentCategory || minPrice || maxPrice || currentGender) { %>
                        Try removing a filter, or browse all listings below.
                    <% } else { %>
                        Try a different search, or explore by category below.
                    <% } %>
                </p>
                <a href="/listings" class="btn no-results-reset-btn">
                    <i class="fa-solid fa-rotate-left me-1"></i> Reset & view all listings
                </a>
            </div>

            <div class="no-results-categories">
                <h6>Browse by category</h6>
                <div class="no-results-cat-grid">
                    <% CATEGORIES.slice(0, 8).forEach(cat => { %>
                        <a href="/listings?category=<%= cat.key %>" class="no-results-cat-pill">
                            <i class="<%= cat.icon %>"></i>
                            <span><%= cat.label %></span>
                        </a>
                    <% }) %>
                </div>
            </div>

            <% if (typeof suggestions !== 'undefined' && suggestions.length > 0) { %>
                <div class="no-results-suggestions">
                    <h6>Popular listings you might like</h6>
                    <div class="row row-cols-md-4 row-cols-2 g-3">
                        <% suggestions.forEach(s => { %>
                            <div class="col">
                                <a href="/listings/<%= s._id %>" class="suggestion-card">
                                    <div class="suggestion-img">
                                        <img src="<%= (s.image && s.image[0]) ? cardThumb(s.image[0].url) : 'https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?w=400' %>" alt="">
                                    </div>
                                    <div class="suggestion-info">
                                        <div class="suggestion-title"><%= s.title %></div>
                                        <div class="suggestion-loc"><i class="fa-solid fa-location-dot"></i> <%= s.location %></div>
                                        <% if (s.avgRating > 0) { %>
                                            <div class="suggestion-rating"><i class="fa-solid fa-star"></i> <%= s.avgRating %></div>
                                        <% } %>
                                    </div>
                                </a>
                            </div>
                        <% }) %>
                    </div>
                </div>
            <% } %>
        </div>
    <% } else { %>
    <div class="row row-cols-xxl-4 row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
        <% for(let listing of allListings) { %>
            <div class="col listing-col">
                <a href="/listings/<%= listing._id %>" class="listing-link">
                    <div class="card listing-card border-0">
                      <div class="img-container">
    <img src="<%= (listing.image && listing.image.length > 0) ? cardThumb(listing.image[0].url) : 'https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?w=500&h=350&fit=crop&auto=format' %>" 
         class="card-img-top" 
         alt="listing_image"
         loading="lazy">
    
    <div class="card-img-overlay p-2">
      <% if (listing.genderPolicy === 'boys') { %>
            <span class="badge gender-badge-boys px-2 py-1" data-tip="Boys only hostel"><i class="fa-solid fa-mars me-1"></i>Boys Only</span>
        <% } else if (listing.genderPolicy === 'girls') { %>
            <span class="badge gender-badge-girls px-2 py-1" data-tip="Girls only hostel"><i class="fa-solid fa-venus me-1"></i>Girls Only</span>
        <% } else { %>
            <span class="badge bg-teal-brand px-2 py-1" data-tip="Recently listed">New</span>
        <% } %>

        <% if (listing.price && listing.price < 5000) { %>
            <span class="badge bg-gold-brand ms-1 px-2 py-1" data-tip="Under ₹5,000/month">Best Value</span>
        <% } %>

        <% if (currUser) { %>
            <button type="button" class="wishlist-icon save-btn" data-listing-id="<%= listing._id %>" onclick="event.preventDefault(); toggleSave(this);">
                <i class="<%= (typeof savedIds !== 'undefined' && savedIds.includes(listing._id.toString())) ? 'fa-solid fa-heart saved' : 'fa-regular fa-heart' %>"></i>
            </button>
        <% } else { %>
            <a href="/login" class="wishlist-icon" onclick="event.stopPropagation();">
                <i class="fa-regular fa-heart"></i>
            </a>
        <% } %>
    </div>
</div>
                        
                        <div class="card-body px-1">
                            <div class="d-flex justify-content-between align-items-start">
                                <span class="listing-title"><b><%= listing.title %></b></span>
                               <% if (listing.avgRating && listing.avgRating > 0) { %>
                                    <span class="text-muted small">
                                        <i class="fa-solid fa-star text-warning"></i> <%= listing.avgRating %>
                                        <span class="d-none d-md-inline text-muted" style="font-size:0.72rem;">(<%= listing.reviewCount %>)</span>
                                    </span>
                                <% } else { %>
                                    <span class="text-muted small" style="font-size:0.72rem;">No reviews</span>
                                <% } %>
                            </div>
                            <p class="card-text">
                           <span class="listing-price">&#x20B9; <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %></span>
                                <%
                                  const cardPlan = typeof PRICE_PLANS !== 'undefined' ? PRICE_PLANS.find(p => p.key === listing.pricePlan) : null;
                                %>
                                <span class="per-month"><%= cardPlan ? cardPlan.label : '/ month' %></span>
                                <i class="tax-info text-muted small d-none">+ 18% GST</i>
                            </p>
                          <% if (listing.category && listing.category.length > 0) { %>
                                <div class="category-pills">
                                    <% listing.category.forEach(catKey => {
                                        const cat = CATEGORIES.find(c => c.key === catKey);
                                        if (cat) { %>
                                            <span class="category-pill"><i class="<%= cat.icon %>"></i> <%= cat.label %></span>
                                        <% } 
                                    }) %>
                                </div>
                            <% } %>

                            <% 
                                const cardAmenityKeys = listing.amenities || [];
                                const cardAmenities = cardAmenityKeys
                                    .map(key => ALL_AMENITIES[key])
                                    .filter(Boolean);
                            %>
                            <% if (cardAmenities.length > 0) { %>
                                <div class="card-amenities-wrap">
                                    <div class="card-amenities-preview">
                                        <% cardAmenities.slice(0, 3).forEach(am => { %>
                                            <span class="card-amenity-tag"><i class="<%= am.icon %>"></i> <%= am.label %></span>
                                        <% }) %>
                                    </div>
                                    <% if (cardAmenities.length > 3) { %>
                                        <div class="card-amenities-extra" style="display:none;">
                                            <% cardAmenities.slice(3).forEach(am => { %>
                                                <span class="card-amenity-tag"><i class="<%= am.icon %>"></i> <%= am.label %></span>
                                            <% }) %>
                                        </div>
                                        <button type="button" class="card-amenities-toggle" onclick="event.preventDefault(); event.stopPropagation(); toggleCardAmenities(this);">
                                            <span>+<%= cardAmenities.length - 3 %> more</span>
                                            <i class="fa-solid fa-chevron-down"></i>
                                        </button>
                                    <% } %>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </a>
            </div>
        <% } %>
    </div>

    <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
        <nav class="pagination-wrapper mt-4" aria-label="Listings pagination">
            <ul class="pagination justify-content-center">
                <li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>">
                    <a class="page-link" href="<%= buildUrl({ page: currentPage - 1 }) %>" aria-label="Previous">
                        <i class="fa-solid fa-chevron-left"></i>
                    </a>
                </li>

                <%
                  const windowSize = 2;
                  const pages = [];
                  for (let p = 1; p <= totalPages; p++) {
                      if (p === 1 || p === totalPages || (p >= currentPage - windowSize && p <= currentPage + windowSize)) {
                          pages.push(p);
                      }
                  }
                %>
                <% let lastShown = 0; %>
                <% pages.forEach(p => { %>
                    <% if (p - lastShown > 1) { %>
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                    <% } %>
                    <li class="page-item <%= p === currentPage ? 'active' : '' %>">
                        <a class="page-link" href="<%= buildUrl({ page: p }) %>"><%= p %></a>
                    </li>
                    <% lastShown = p; %>
                <% }) %>

                <li class="page-item <%= currentPage >= totalPages ? 'disabled' : '' %>">
                    <a class="page-link" href="<%= buildUrl({ page: currentPage + 1 }) %>" aria-label="Next">
                        <i class="fa-solid fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
            <p class="text-center text-muted small mb-0">Page <%= currentPage %> of <%= totalPages %> &middot; <%= totalCount %> total listings</p>
        </nav>
    <% } %>
    <% } %>
    <script>
    // Pass server-side search context to client JS
    window.__UNINEST__ = {
        searchQuery: '<%= typeof searchQuery !== "undefined" ? searchQuery : "" %>',
        searchCenter: '<%= typeof searchCenter !== "undefined" && searchCenter ? JSON.stringify({ lat: searchCenter[1], lng: searchCenter[0] }) : "null" %>',
        currentCategory: '<%= typeof currentCategory !== "undefined" && currentCategory ? currentCategory : "" %>',
        locationIqKey: '<%= process.env.LOCATION_IQ_KEY %>',
    };
</script>
<script>
(function() {
    const track = document.getElementById('filters');
    const leftBtn = document.getElementById('filterLeft');
    const rightBtn = document.getElementById('filterRight');
    if (!track) return;

    const SCROLL_AMOUNT = 200;

    function updateArrows() {
        leftBtn.style.opacity = track.scrollLeft > 10 ? '1' : '0.3';
        leftBtn.style.pointerEvents = track.scrollLeft > 10 ? 'auto' : 'none';
        const atEnd = track.scrollLeft + track.clientWidth >= track.scrollWidth - 10;
        rightBtn.style.opacity = atEnd ? '0.3' : '1';
        rightBtn.style.pointerEvents = atEnd ? 'none' : 'auto';
    }

    leftBtn.addEventListener('click', () => {
        track.scrollBy({ left: -SCROLL_AMOUNT, behavior: 'smooth' });
    });
    rightBtn.addEventListener('click', () => {
        track.scrollBy({ left: SCROLL_AMOUNT, behavior: 'smooth' });
    });

    track.addEventListener('scroll', updateArrows);
    updateArrows();

    // Scroll active filter into view on load
    const activeFilter = track.querySelector('.filter.active');
    if (activeFilter) {
        setTimeout(() => activeFilter.scrollIntoView({ inline: 'center', behavior: 'smooth', block: 'nearest' }), 100);
    }
})();
</script>
<script>
function toggleCardAmenities(btn) {
    const wrap = btn.closest('.card-amenities-wrap');
    const extra = wrap.querySelector('.card-amenities-extra');
    const icon = btn.querySelector('i');
    const label = btn.querySelector('span');
    const isHidden = extra.style.display === 'none';

    extra.style.display = isHidden ? 'flex' : 'none';
    icon.style.transform = isHidden ? 'rotate(180deg)' : 'rotate(0deg)';
    label.textContent = isHidden ? 'Show less' : `+${extra.children.length} more`;
}
</script>
</div>
