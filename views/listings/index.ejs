<% layout("/layouts/boilerplate")%>
<link rel="stylesheet" href="/css/index-ejs.css">
<%
  // Helper to build a query string that preserves existing filters while changing one param
  function buildUrl(overrides) {
    const params = new URLSearchParams();
    if (typeof currentCategory !== 'undefined' && currentCategory) params.set('category', currentCategory);
    if (typeof searchQuery !== 'undefined' && searchQuery) params.set('q', searchQuery);
    if (typeof minPrice !== 'undefined' && minPrice) params.set('minPrice', minPrice);
    if (typeof maxPrice !== 'undefined' && maxPrice) params.set('maxPrice', maxPrice);
    if (typeof currentSort !== 'undefined' && currentSort) params.set('sort', currentSort);
    if (typeof currentPage !== 'undefined' && currentPage > 1) params.set('page', currentPage);

    Object.keys(overrides).forEach(key => {
      if (overrides[key] === null || overrides[key] === '') {
        params.delete(key);
      } else {
        params.set(key, overrides[key]);
      }
    });

    const base = (typeof searchQuery !== 'undefined' && searchQuery) ? '/listings/search' : '/listings';
    const qs = params.toString();
    return qs ? `${base}?${qs}` : base;
  }

  const sortLabels = {
    recommended: "Recommended",
    price_asc: "Price: Low to High",
    price_desc: "Price: High to Low",
    rating_desc: "Top Rated",
    newest: "Newest First",
  };
  const activeSort = (typeof currentSort !== 'undefined' && currentSort) ? currentSort : "recommended";
%>

<div class="index-container">
    <div class="filters-wrapper d-flex align-items-center justify-content-between py-3">
        <div id="filters">
            <a href="<%= buildUrl({ category: null, page: null }) %>" class="filter <%= !currentCategory ? 'active' : '' %>">
                <i class="fa-solid fa-layer-group"></i>
                <p>All</p>
            </a>
            <% CATEGORIES.forEach(cat => { %>
                <a href="<%= buildUrl({ category: cat.key, page: null }) %>" class="filter <%= currentCategory === cat.key ? 'active' : '' %>">
                    <i class="<%= cat.icon %>"></i>
                    <p><%= cat.label %></p>
                </a>
            <% }) %>
        </div>
    </div>

    <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
        <div class="search-results-banner mb-3">
            <i class="fa-solid fa-magnifying-glass"></i>
            Showing results for "<%= searchQuery %>"
            <% if (searchCenter) { %><span class="text-muted">— including nearby places</span><% } %>
            <a href="/listings" class="ms-2 clear-filter-link"><i class="fa-solid fa-xmark"></i> Clear</a>
        </div>
    <% } %>

    <div class="result-info d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3 px-1">
        <h6 class="text-muted fw-normal mb-0">
            Showing <%= allListings.length %> available place<%= allListings.length === 1 ? '' : 's' %>
            <% if (currentCategory) {
                const activeCat = CATEGORIES.find(c => c.key === currentCategory);
            %>
                for "<%= activeCat ? activeCat.label : currentCategory %>"
            <% } %>
            <% if (currentCategory || minPrice || maxPrice) { %>
                <a href="<%= (typeof searchQuery !== 'undefined' && searchQuery) ? '/listings/search?q=' + encodeURIComponent(searchQuery) : '/listings' %>" class="ms-2 clear-filter-link"><i class="fa-solid fa-xmark"></i> Clear filters</a>
            <% } %>
        </h6>

        <div class="d-flex align-items-center gap-2">
            <form method="GET" action="<%= (typeof searchQuery !== 'undefined' && searchQuery) ? '/listings/search' : '/listings' %>" class="price-range-form d-flex align-items-center gap-1">
                <% if (typeof searchQuery !== 'undefined' && searchQuery) { %><input type="hidden" name="q" value="<%= searchQuery %>"><% } %>
                <% if (currentCategory) { %><input type="hidden" name="category" value="<%= currentCategory %>"><% } %>
                <% if (currentSort) { %><input type="hidden" name="sort" value="<%= currentSort %>"><% } %>
                <input type="number" name="minPrice" value="<%= minPrice %>" placeholder="Min ₹" class="price-input" min="0">
                <span class="text-muted small">–</span>
                <input type="number" name="maxPrice" value="<%= maxPrice %>" placeholder="Max ₹" class="price-input" min="0">
                <button type="submit" class="btn btn-sm price-apply-btn">Go</button>
            </form>

            <div class="dropdown">
                <button class="btn btn-sm btn-outline-secondary dropdown-toggle rounded-pill px-3" type="button" data-bs-toggle="dropdown">
                    Sort by: <%= sortLabels[activeSort] %>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <% Object.keys(sortLabels).forEach(key => { %>
                        <li><a class="dropdown-item <%= activeSort === key ? 'active' : '' %>" href="<%= buildUrl({ sort: key === 'recommended' ? null : key, page: null }) %>"><%= sortLabels[key] %></a></li>
                    <% }) %>
                </ul>
            </div>
        </div>
    </div>

    <% if (allListings.length === 0) { %>
        <div class="empty-state">
            <i class="fa-solid fa-magnifying-glass"></i>
            <h5>No listings match these filters</h5>
            <p class="mb-0"><a href="/listings">View all listings</a> or try a different price range.</p>
        </div>
    <% } else { %>
    <div class="row row-cols-xxl-4 row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
        <% for(let listing of allListings) { %>
            <div class="col listing-col">
                <a href="/listings/<%= listing._id %>" class="listing-link">
                    <div class="card listing-card border-0">
                       <div class="img-container">
    <img src="<%= (listing.image && listing.image.length > 0) ? cardThumb(listing.image[0].url) : 'https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?w=500&h=350&fit=crop&auto=format' %>" 
         class="card-img-top" 
         alt="listing_image"
         loading="lazy">
    
    <div class="card-img-overlay p-2">
        <span class="badge bg-teal-brand px-2 py-1">New</span>
        
        <% if(listing.price < 5000) { %>
            <span class="badge bg-gold-brand ms-1 px-2 py-1">Best Value</span>
        <% } %>
        
       <% if (currUser) { %>
            <button type="button" class="wishlist-icon save-btn" data-listing-id="<%= listing._id %>" onclick="event.preventDefault(); toggleSave(this);">
                <i class="<%= (typeof savedIds !== 'undefined' && savedIds.includes(listing._id.toString())) ? 'fa-solid fa-heart saved' : 'fa-regular fa-heart' %>"></i>
            </button>
        <% } else { %>
            <a href="/login" class="wishlist-icon" onclick="event.stopPropagation();">
                <i class="fa-regular fa-heart"></i>
            </a>
        <% } %>
    </div>
</div>
                        
                        <div class="card-body px-1">
                            <div class="d-flex justify-content-between align-items-start">
                                <span class="listing-title"><b><%= listing.title %></b></span>
                                <span class="text-muted small"><i class="fa-solid fa-star text-warning"></i> 4.5</span>
                            </div>
                            <p class="card-text">
                                <span class="listing-price">&#x20B9; <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %></span> 
                                <span class="per-month">/ month</span>
                                <i class="tax-info text-muted small d-none">+ 18% GST</i>
                            </p>
                            <% if (listing.category && listing.category.length > 0) { %>
                                <div class="category-pills">
                                    <% listing.category.forEach(catKey => {
                                        const cat = CATEGORIES.find(c => c.key === catKey);
                                        if (cat) { %>
                                            <span class="category-pill"><i class="<%= cat.icon %>"></i> <%= cat.label %></span>
                                        <% } 
                                    }) %>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </a>
            </div>
        <% } %>
    </div>

    <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
        <nav class="pagination-wrapper mt-4" aria-label="Listings pagination">
            <ul class="pagination justify-content-center">
                <li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>">
                    <a class="page-link" href="<%= buildUrl({ page: currentPage - 1 }) %>" aria-label="Previous">
                        <i class="fa-solid fa-chevron-left"></i>
                    </a>
                </li>

                <%
                  const windowSize = 2;
                  const pages = [];
                  for (let p = 1; p <= totalPages; p++) {
                      if (p === 1 || p === totalPages || (p >= currentPage - windowSize && p <= currentPage + windowSize)) {
                          pages.push(p);
                      }
                  }
                %>
                <% let lastShown = 0; %>
                <% pages.forEach(p => { %>
                    <% if (p - lastShown > 1) { %>
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                    <% } %>
                    <li class="page-item <%= p === currentPage ? 'active' : '' %>">
                        <a class="page-link" href="<%= buildUrl({ page: p }) %>"><%= p %></a>
                    </li>
                    <% lastShown = p; %>
                <% }) %>

                <li class="page-item <%= currentPage >= totalPages ? 'disabled' : '' %>">
                    <a class="page-link" href="<%= buildUrl({ page: currentPage + 1 }) %>" aria-label="Next">
                        <i class="fa-solid fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
            <p class="text-center text-muted small mb-0">Page <%= currentPage %> of <%= totalPages %> &middot; <%= totalCount %> total listings</p>
        </nav>
    <% } %>
    <% } %>
</div>