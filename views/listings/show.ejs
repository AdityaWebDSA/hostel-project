<% layout("/layouts/boilerplate")%>
<link rel="stylesheet" href="/css/show-ejs.css">

<div class="show-page-wrapper">
    <div class="hero-container position-relative">
        <img src="<%= listing.image.url %>" class="hero-img" alt="listing_image">
        <div class="hero-overlay">
            <div class="container h-100 d-flex flex-column justify-content-end pb-4">
                <h1 class="hero-title"><%= listing.title %></h1>
                <p class="hero-location"><i class="fa-solid fa-location-dot me-2"></i><%= listing.location %>, <%= listing.country %></p>
            </div>
        </div>
    </div>

    <div class="container mt-5">
        <div class="row gx-lg-5">
            <div class="col-lg-8">
                <div class="host-info-card d-flex align-items-center p-3 mb-4">
                    <div class="user-avatar">
                        <i class="fa-solid fa-user-tie"></i>
                    </div>
                    <div class="ms-3">
                        <h5 class="mb-0">Hosted by <%= listing.owner.username %></h5>
                        <small class="text-muted">Verified Property Owner</small>
                    </div>
                </div>

                <div class="description-section mb-5">
                    <h4 class="section-label">About this place</h4>
                    <p class="description-body"><%= listing.description %></p>
                </div>

                <div class="amenities-grid mb-5">
                    <h4 class="section-label">Amenities</h4>
                    <div class="row g-3">
                        <div class="col-6 col-md-4"><i class="fa-solid fa-wifi me-2 text-teal"></i> High-speed Wi-Fi</div>
                        <div class="col-6 col-md-4"><i class="fa-solid fa-bolt me-2 text-teal"></i> 24/7 Power Backup</div>
                        <div class="col-6 col-md-4"><i class="fa-solid fa-bucket me-2 text-teal"></i> Daily Cleaning</div>
                        <div class="col-6 col-md-4"><i class="fa-solid fa-shield-halved me-2 text-teal"></i> CCTV Security</div>
                        <div class="col-6 col-md-4"><i class="fa-solid fa-faucet me-2 text-teal"></i> RO Water</div>
                    </div>
                </div>

                <% if(currUser && currUser._id.equals(listing.owner._id)) { %>
                    <div class="owner-actions p-4 rounded-4 d-flex gap-3">
                        <a href="/listings/<%= listing._id %>/edit" class="btn btn-edit-premium flex-grow-1">
                            <i class="fa-solid fa-sliders me-2"></i>Manage Listing
                        </a>
                        <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="flex-grow-1">
                            <button class="btn btn-delete-premium w-100">
                                <i class="fa-solid fa-trash-can me-2"></i>Remove
                            </button>
                        </form>
                    </div>
                <% } %>
            </div>

            <div class="col-lg-4">
                <div class="booking-card sticky-top shadow-lg">
                    <div class="price-header d-flex justify-content-between align-items-center">
                        <div>
                            <span class="price-big">&#x20B9;<%= listing.price.toLocaleString("en-IN") %></span>
                            <span class="text-muted">/month</span>
                        </div>
                        <div class="rating-badge">
                            <i class="fa-solid fa-star"></i> 4.8
                        </div>
                    </div>
                    <hr>
                    <div class="booking-details mb-4">
                        <p class="mb-1"><i class="fa-solid fa-check text-success me-2"></i>Instalment option available</p>
                        <p class="mb-0"><i class="fa-solid fa-check text-success me-2"></i>Refundable deposit</p>
                    </div>
                    <button class="btn btn-book-now w-100 mb-3 py-3">Book Now</button>
                    <p class="text-center small text-muted">You won't be charged yet</p>
                </div>
            </div>
        </div>

        <div class="row mt-5 pt-5 border-top">
            <div class="col-12 mb-5">
                <h4 class="section-label mb-4">Where you'll be staying</h4>
                <div id="map" class="map-premium"></div>
            </div>

          <div class="col-12">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="section-label">Reviews (<%= listing.reviews.length %>)</h4>
        <% if(currUser) { %>
            <button class="btn btn-book-now mb-3 " data-bs-toggle="collapse" data-bs-target="#reviewForm">
                Write a Review
            </button>
        <% } %>
    </div>

    <div class="collapse mb-5" id="reviewForm">
        <div class="card card-body border-0 shadow-sm rounded-4 p-4">
            <h5 class="mb-3">Share your experience</h5>
            <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
                
                <div class="mb-3">
                    <label class="form-label">Rating</label>
               <div class="mb-3">
    <label class="form-label">Rating</label>
    <fieldset class="starability-slot">
        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
        <input type="radio" id="first-rate1" name="review[rating]" value="1" />
        <label for="first-rate1" title="Terrible">1 star</label>
        <input type="radio" id="first-rate2" name="review[rating]" value="2" />
        <label for="first-rate2" title="Not good">2 stars</label>
        <input type="radio" id="first-rate3" name="review[rating]" value="3" />
        <label for="first-rate3" title="Average">3 stars</label>
        <input type="radio" id="first-rate4" name="review[rating]" value="4" />
        <label for="first-rate4" title="Very good">4 stars</label>
        <input type="radio" id="first-rate5" name="review[rating]" value="5" />
        <label for="first-rate5" title="Amazing">5 stars</label>
    </fieldset>
</div>
                </div>

                <div class="mb-3">
                    <label for="comment" class="form-label">Comment</label>
                    <textarea 
                        name="review[comment]" 
                        id="comment" 
                        cols="30" 
                        rows="4" 
                        class="form-control custom-input" 
                        required 
                        placeholder="Tell us about the hostel, mess, or owner..."></textarea>
                    <div class="invalid-feedback">Please add a comment before submitting.</div>
                </div>

                <button class="btn btn-teal-solid px-5 rounded-pill">Submit Review</button>
            </form>
        </div>
    </div>

    <div class="row g-4">
        <% for(let review of listing.reviews) { %>
            <div class="col-md-6">
                <div class="review-card-modern p-4 h-100">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="mb-0 review-author">@<%= review.author.username %></h6>
                        <p class="starability-result" data-rating="<%= review.rating %>"></p>
                    </div>
                    <p class="review-text">"<%= review.comment %>"</p>
                    
                    <% if(currUser && currUser._id.equals(review.author._id)) { %>
                        <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                            <button class="btn btn-sm btn-outline-danger border-0 mt-2">
                                <i class="fa-solid fa-trash-can me-1"></i>Delete Review
                            </button>
                        </form>
                    <% } %>
                </div>
            </div>
        <% } %>
    </div>
</div>
<script>
    // Store the key as a string
    const mapKey = "<%= process.env.LOCATION_IQ_KEY %>";
    
    // Fix: Wrap the EJS tag in backticks or quotes to stop the syntax error,
    // then parse it so it becomes a real JS object.
    const listing = <%- JSON.stringify(listing) %>;
</script>
<script src="/js/map.js"></script>