<% layout("/layouts/boilerplate")%>
<link rel="stylesheet" href="/css/show-ejs.css">

<div class="show-page-wrapper">

    <div class="container pt-3">
        <a href="/listings" class="back-link"><i class="fa-solid fa-arrow-left"></i> Back to listings</a>
    </div>

<% 
        const hasImages = listing.image && listing.image.length > 0;
        const galleryImages = hasImages 
            ? listing.image.map(img => ({ thumb: smallThumb(img.url), full: detailImage(img.url) }))
            : [{ thumb: 'https://images.unsplash.com/photo-1522708323590-d24dbb6b0267', full: 'https://images.unsplash.com/photo-1522708323590-d24dbb6b0267' }];
    %>
<div class="container px-0 px-md-3">
    <div class="bento-gallery-wrapper mb-4">
        <div class="bento-grid">
            <div class="bento-item main-img" onclick="openLightbox(0)">
                <img src="<%= galleryImages[0].full %>" id="mainDisplayImg" alt="Main Image">
                <div class="img-zoom-hint"><i class="fa-solid fa-expand"></i></div>
            </div>

            <div class="side-grid">
                <% for(let i = 1; i < 5; i++) { %>
                    <div class="bento-item small-img">
                        <% if (galleryImages[i]) { %>
                            <img src="<%= galleryImages[i].thumb %>" onclick="openLightbox(<%= i %>)" class="clickable-thumb" alt="Room View">
                        <% } else { %>
                            <div class="img-placeholder d-flex align-items-center justify-content-center">
                                <i class="fa-solid fa-camera text-muted"></i>
                            </div>
                        <% } %>

                        <% if (galleryImages[i] && i === 4 && galleryImages.length > 5) { %>
                            <div class="show-all-overlay" onclick="openLightbox(4)">
                                <span>+<%= galleryImages.length - 5 %> Photos</span>
                            </div>
                        <% } %>
                    </div>
                <% } %>
            </div>
        </div>

        <% if (galleryImages.length > 1) { %>
            <button type="button" class="view-all-photos-btn" onclick="openLightbox(0)">
                <i class="fa-solid fa-images me-2"></i>View all <%= galleryImages.length %> photos
            </button>
        <% } %>
    </div>
</div>
 

    <!-- Lightbox -->
    <!-- Lightbox -->
    <div id="lightboxOverlay" class="lightbox-overlay">
        <div class="lightbox-top-bar">
            <span id="lightboxCounter" class="lightbox-counter">1 / <%= galleryImages.length %></span>
            <button type="button" class="lightbox-close" onclick="closeLightbox()" aria-label="Close">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <div class="lightbox-main">
            <button type="button" class="lightbox-nav lightbox-prev" onclick="lightboxNav(-1)" aria-label="Previous">
                <i class="fa-solid fa-chevron-left"></i>
            </button>

            <div class="lightbox-image-wrap">
                <img id="lightboxImage" src="" alt="Listing photo">
            </div>

            <button type="button" class="lightbox-nav lightbox-next" onclick="lightboxNav(1)" aria-label="Next">
                <i class="fa-solid fa-chevron-right"></i>
            </button>
        </div>

        <div class="lightbox-thumbstrip" id="lightboxThumbstrip"></div>
    </div>

    <script>
        const GALLERY_IMAGES = <%- JSON.stringify(galleryImages) %>;
        let lightboxIndex = 0;

        function buildThumbstrip() {
            const strip = document.getElementById('lightboxThumbstrip');
            strip.innerHTML = GALLERY_IMAGES.map((img, i) =>
                `<img src="${img.thumb}" data-idx="${i}" class="lightbox-thumb ${i === lightboxIndex ? 'active' : ''}" onclick="setLightboxImage(${i})">`
            ).join('');
        }

        function setLightboxImage(idx) {
            lightboxIndex = (idx + GALLERY_IMAGES.length) % GALLERY_IMAGES.length;
            document.getElementById('lightboxImage').src = GALLERY_IMAGES[lightboxIndex].full;
            document.getElementById('lightboxCounter').textContent = `${lightboxIndex + 1} / ${GALLERY_IMAGES.length}`;
            document.querySelectorAll('.lightbox-thumb').forEach((t, i) => t.classList.toggle('active', i === lightboxIndex));

            // Keep active thumb scrolled into view
            const activeThumb = document.querySelector('.lightbox-thumb.active');
            activeThumb?.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
        }

        function openLightbox(idx) {
            lightboxIndex = idx;
            buildThumbstrip();
            setLightboxImage(idx);
            document.getElementById('lightboxOverlay').classList.add('lightbox-active');
            document.body.style.overflow = 'hidden';
        }

        function closeLightbox() {
            document.getElementById('lightboxOverlay').classList.remove('lightbox-active');
            document.body.style.overflow = '';
        }

        function lightboxNav(dir) {
            setLightboxImage(lightboxIndex + dir);
        }

        // Keyboard navigation
        document.addEventListener('keydown', (e) => {
            const overlay = document.getElementById('lightboxOverlay');
            if (!overlay.classList.contains('lightbox-active')) return;
            if (e.key === 'Escape') closeLightbox();
            if (e.key === 'ArrowLeft') lightboxNav(-1);
            if (e.key === 'ArrowRight') lightboxNav(1);
        });

        // Click outside image to close
        document.getElementById('lightboxOverlay').addEventListener('click', (e) => {
            if (e.target.id === 'lightboxOverlay' || e.target.classList.contains('lightbox-image-wrap')) {
                closeLightbox();
            }
        });

        // Swipe support for mobile
        let touchStartX = 0;
        const lightboxMain = document.querySelector('.lightbox-main');
        lightboxMain?.addEventListener('touchstart', (e) => touchStartX = e.touches[0].clientX);
        lightboxMain?.addEventListener('touchend', (e) => {
            const diff = touchStartX - e.changedTouches[0].clientX;
            if (Math.abs(diff) > 50) lightboxNav(diff > 0 ? 1 : -1);
        });
    </script>

    <div class="container mt-4">

        <div class="listing-header mb-4">
            <h2 class="listing-show-title"><%= listing.title %></h2>
            <p class="listing-show-location">
                <i class="fa-solid fa-location-dot"></i>
                <%= listing.landmark ? listing.landmark + ", " : "" %><%= listing.location %><%= listing.country ? ", " + listing.country : "" %>
            </p>
        </div>

        <div class="d-flex align-items-center gap-2 flex-wrap mb-3">
            <% if (listing.genderPolicy === 'boys') { %>
                <span class="gender-show-badge boys"><i class="fa-solid fa-mars"></i> Boys Only</span>
            <% } else if (listing.genderPolicy === 'girls') { %>
                <span class="gender-show-badge girls"><i class="fa-solid fa-venus"></i> Girls Only</span>
            <% } else if (listing.genderPolicy === 'coed') { %>
                <span class="gender-show-badge coed"><i class="fa-solid fa-venus-mars"></i> Co-ed / All</span>
            <% } %>
        </div>

        <% if (listing.category && listing.category.length > 0) { %>
            <div class="category-pills-show mb-4">
                <% listing.category.forEach(catKey => {
                    const cat = typeof CATEGORIES !== 'undefined' ? CATEGORIES.find(c => c.key === catKey) : null;
                    if (cat) { %>
                        <span class="category-pill-lg"><i class="<%= cat.icon %>"></i> <%= cat.label %></span>
                    <% }
                }) %>
            </div>
        <% } %>

        <div class="row gx-lg-5">
            <div class="col-lg-8">
                <div class="host-info-card d-flex align-items-center p-3 mb-4">
                    <div class="user-avatar">
                        <%= listing.owner && listing.owner.username ? listing.owner.username.charAt(0).toUpperCase() : "?" %>
                    </div>
                    <div class="ms-3">
                        <h6 class="mb-0 host-name">Hosted by <%= listing.owner ? listing.owner.username : "Unknown" %></h6>
                        <small class="text-muted">Verified Owner</small>
                    </div>
                </div>

                <div class="description-section mb-5">
                    <h4 class="section-label">About this place</h4>
                    <p class="description-body"><%= listing.description %></p>
                </div>

                <% if ((listing.amenities && listing.amenities.length > 0) || listing.customAmenities) { %>
                <div class="amenities-grid mb-5">
                    <h4 class="section-label">What to expect</h4>
                    <div class="row g-3">
                        <% if (listing.amenities && listing.amenities.length > 0 && typeof ALL_AMENITIES !== 'undefined') { %>
                            <% listing.amenities.forEach(key => {
                                const amenity = ALL_AMENITIES[key];
                                if (amenity) { %>
                                    <div class="col-6 col-md-4 amenity-item">
                                        <i class="<%= amenity.icon %>"></i> <%= amenity.label %>
                                    </div>
                                <% }
                            }) %>
                        <% } %>
                        <% if (listing.customAmenities) {
                            listing.customAmenities.split(',').map(s => s.trim()).filter(Boolean).forEach(item => { %>
                                <div class="col-6 col-md-4 amenity-item">
                                    <i class="fa-solid fa-circle-check"></i> <%= item %>
                                </div>
                            <% })
                        } %>
                    </div>
                </div>
                <% } %>

                <% if(typeof currUser !== 'undefined' && currUser && listing.owner && currUser._id.equals(listing.owner._id)) { %>
                    <div class="owner-actions p-4 rounded-4 d-flex gap-3">
                        <a href="/listings/<%= listing._id %>/edit" class="btn btn-edit-premium flex-grow-1">
                            <i class="fa-solid fa-sliders me-2"></i>Manage Listing
                        </a>
                        <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="flex-grow-1">
                            <button class="btn btn-delete-premium w-100">
                                <i class="fa-solid fa-trash-can me-2"></i>Remove
                            </button>
                        </form>
                    </div>
                <% } %>
            </div>

            <div class="col-lg-4">
                <div class="booking-card sticky-top shadow-lg">
                    <div class="price-header d-flex justify-content-between align-items-center">
                        <div>
                            <% if (listing.price && listing.price > 0) { %>
                                <span class="price-big">₹<%= listing.price.toLocaleString("en-IN") %></span>
                                <%
                                  const activePlan = typeof PRICE_PLANS !== 'undefined'
                                    ? PRICE_PLANS.find(p => p.key === listing.pricePlan)
                                    : null;
                                  const planSuffix = activePlan ? activePlan.label : '/ month';
                                %>
                                <span class="text-muted"><%= planSuffix %></span>
                            <% } else { %>
                                <span class="price-big price-service">Contact for Price</span>
                            <% } %>
                        </div>
                        <div class="rating-badge">
                            <i class="fa-solid fa-star"></i>
                            <% if (typeof reviewCount !== 'undefined' && reviewCount > 0) { %>
                                <%= avgRating %> <span class="review-count">(<%= reviewCount %>)</span>
                            <% } else { %>
                                New
                            <% } %>
                        </div>
                    </div>
                    <hr>
                    <div class="booking-details mb-4">
                        <% if (listing.pricePlan && typeof PRICE_PLANS !== 'undefined') {
                            const shownPlan = PRICE_PLANS.find(p => p.key === listing.pricePlan);
                        %>
                            <p class="mb-2 fw-semibold" style="font-size:0.85rem; color:var(--color-text-muted); text-transform:uppercase; letter-spacing:0.5px;">Billing</p>
                            <div class="billing-pills">
                                <span class="billing-pill">
                                    <i class="fa-solid fa-calendar-check"></i>
                                    <%= shownPlan ? shownPlan.label : listing.pricePlan %>
                                </span>
                            </div>
                        <% } %>
                        <p class="mb-0 mt-3"><i class="fa-solid fa-check text-success me-1"></i>Refundable deposit</p>
                    </div>
                    <% if (typeof currUser !== 'undefined' && currUser) { %>
                        <button type="button" class="btn btn-save-listing w-100 mb-2" data-listing-id="<%= listing._id %>" onclick="toggleSave(this)">
                            <i class="<%= typeof isSaved !== 'undefined' && isSaved ? 'fa-solid fa-heart saved' : 'fa-regular fa-heart' %>"></i>
                            <span><%= typeof isSaved !== 'undefined' && isSaved ? 'Saved' : 'Save to Wishlist' %></span>
                        </button>

                        <% if (listing.owner && !listing.owner._id.equals(currUser._id)) { %>
                            <button type="button" class="btn btn-book-now w-100 mb-3 py-3" data-bs-toggle="modal" data-bs-target="#bookingModal">
                                Request to Book
                            </button>
                            <p class="text-center small text-muted mb-0">You won't be charged yet</p>
                        <% } else { %>
                            <p class="text-center small text-muted mb-0 mt-2">This is your own listing</p>
                        <% } %>
                    <% } else { %>
                        <a href="/login" class="btn btn-book-now w-100 mb-3 py-3 d-block text-center text-decoration-none">Log in to Book</a>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="row mt-5 pt-5 border-top">
            <div class="col-12 mb-4">
                <h4 class="section-label mb-4">Where you'll be staying</h4>
            </div>

            <div class="col-lg-5 mb-4 mb-lg-0">
                <div class="location-info-card">
                    <h6 class="location-card-title"><i class="fa-solid fa-location-dot"></i> Address</h6>
                    <p class="location-address">
                        <%= listing.landmark ? listing.landmark + ", " : "" %><%= listing.location %><%= listing.country ? ", " + listing.country : "" %>
                    </p>

                    <% if (listing.geometry && listing.geometry.coordinates && listing.geometry.coordinates.length >= 2) { %>
                        <a href="https://www.google.com/maps/search/?api=1&query=<%= listing.geometry.coordinates[1] %>,<%= listing.geometry.coordinates[0] %>"
                           target="_blank" rel="noopener" class="contact-action-btn directions-btn">
                            <i class="fa-solid fa-diamond-turn-right"></i> Get Directions
                        </a>
                    <% } %>

                    <hr class="my-4">

                    <h6 class="location-card-title"><i class="fa-solid fa-address-card"></i> Contact</h6>

                    <% if (listing.contactNumber || listing.contactEmail) { %>
                        <div class="contact-actions">
                            <% if (listing.contactNumber) { %>
                                <a href="tel:<%= listing.contactNumber %>" class="contact-action-btn">
                                    <i class="fa-solid fa-phone"></i> Call <%= listing.contactNumber %>
                                </a>
                                <a href="https://wa.me/<%= listing.contactNumber.replace(/[^0-9]/g, '') %>" target="_blank" rel="noopener" class="contact-action-btn whatsapp-btn">
                                    <i class="fa-brands fa-whatsapp"></i> WhatsApp
                                </a>
                            <% } %>
                            <% if (listing.contactEmail) { %>
                                <a href="mailto:<%= listing.contactEmail %>" class="contact-action-btn email-btn">
                                    <i class="fa-solid fa-envelope"></i> Email
                                </a>
                            <% } %>
                        </div>
                    <% } else { %>
                        <p class="text-muted small mb-0">The owner hasn't added contact details yet.</p>
                    <% } %>
                </div>
            </div>

            <div class="col-lg-7">
                <div id="map" class="map-premium"></div>
            </div>

           <div class="col-12" id="reviews-section">
                <div class="reviews-header">
                    <div>
                        <h4 class="section-label mb-0">Reviews</h4>
                        <% if (reviewCount > 0) { %>
                            <div class="reviews-summary">
                                <span class="reviews-big-rating"><%= avgRating %></span>
                                <div>
                                    <div class="reviews-stars">
                                        <% for(let s = 1; s <= 5; s++) { %>
                                            <i class="fa-<%= s <= Math.round(avgRating) ? 'solid' : 'regular' %> fa-star"></i>
                                        <% } %>
                                    </div>
                                    <span class="text-muted small"><%= reviewCount %> review<%= reviewCount !== 1 ? 's' : '' %></span>
                                </div>
                            </div>
                        <% } %>
                    </div>
                    <% if(currUser) { %>
                        <button class="btn btn-outline-teal rounded-pill" data-bs-toggle="collapse" data-bs-target="#reviewForm">
                            <i class="fa-solid fa-pen me-1"></i> Write a Review
                        </button>
                    <% } %>
                </div>

                <div class="collapse mb-4" id="reviewForm">
                    <div class="write-review-card">
                        <h6 class="mb-3">Share your experience</h6>
                        <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
                            <div class="mb-3">
                                <label class="form-label small fw-semibold">Rating</label>
                                <fieldset class="starability-slot">
                                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                                    <input type="radio" id="first-rate1" name="review[rating]" value="1" /><label for="first-rate1" title="Terrible">1 star</label>
                                    <input type="radio" id="first-rate2" name="review[rating]" value="2" /><label for="first-rate2" title="Not good">2 stars</label>
                                    <input type="radio" id="first-rate3" name="review[rating]" value="3" /><label for="first-rate3" title="Average">3 stars</label>
                                    <input type="radio" id="first-rate4" name="review[rating]" value="4" /><label for="first-rate4" title="Very good">4 stars</label>
                                    <input type="radio" id="first-rate5" name="review[rating]" value="5" /><label for="first-rate5" title="Amazing">5 stars</label>
                                </fieldset>
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-semibold">Comment</label>
                                <textarea name="review[comment]" rows="3" class="form-control custom-input" required placeholder="Tell others about your experience..."></textarea>
                                <div class="invalid-feedback">Please add a comment.</div>
                            </div>
                            <button class="btn btn-teal-solid rounded-pill px-4" id="reviewSubmitBtn" data-loading-text="Submitting...">
                                <i class="fa-solid fa-paper-plane me-1"></i> Post Review
                            </button>
                        </form>
                    </div>
                </div>

                <% if (listing.reviews.length === 0) { %>
                    <div class="no-reviews-yet">
                        <i class="fa-regular fa-comment-dots"></i>
                        <p class="mb-0">No reviews yet. Be the first to share your experience!</p>
                    </div>
                <% } else { %>
                <div class="reviews-list">
                    <% for(let review of listing.reviews) { %>
                    <div class="review-item" id="review-<%= review._id %>">

                        <div class="review-item-avatar">
                            <%= review.author.username.charAt(0).toUpperCase() %>
                        </div>

                        <div class="review-item-body">
                            <div class="review-item-header">
                                <div class="d-flex align-items-center gap-2 flex-wrap">
                                    <span class="review-username">@<%= review.author.username %></span>
                                    <p class="starability-result mb-0" data-rating="<%= review.rating %>"></p>
                                </div>
                                <span class="review-timestamp">
                                    <%= review.createdAt ? new Date(review.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) : '' %>
                                </span>
                            </div>

                            <p class="review-comment"><%= review.comment %></p>

                            <div class="review-actions">
                                <% const userLikedReview = currUser && review.likes.some(id => id.equals(currUser._id)); %>
                                <% const userDislikedReview = currUser && review.dislikes.some(id => id.equals(currUser._id)); %>

                                <% if (currUser) { %>
                                    <button class="review-action-btn like-btn <%= userLikedReview ? 'active-like' : '' %>"
                                        data-id="<%= review._id %>" data-type="review" data-action="like"
                                        onclick="toggleVote(this)">
                                        <i class="fa-<%= userLikedReview ? 'solid' : 'regular' %> fa-thumbs-up"></i>
                                        <span class="like-count"><%= review.likes.length %></span>
                                    </button>
                                    <button class="review-action-btn dislike-btn <%= userDislikedReview ? 'active-dislike' : '' %>"
                                        data-id="<%= review._id %>" data-type="review" data-action="dislike"
                                        onclick="toggleVote(this)">
                                        <i class="fa-<%= userDislikedReview ? 'solid' : 'regular' %> fa-thumbs-down"></i>
                                        <span class="dislike-count"><%= review.dislikes.length %></span>
                                    </button>
                                    <button class="review-action-btn reply-trigger-btn"
                                        onclick="toggleInlineReply('reply-box-<%= review._id %>')">
                                        <i class="fa-solid fa-reply"></i> Reply
                                    </button>
                                <% } else { %>
                                    <span class="review-vote-count"><i class="fa-regular fa-thumbs-up"></i> <%= review.likes.length %></span>
                                    <span class="review-vote-count"><i class="fa-regular fa-thumbs-down"></i> <%= review.dislikes.length %></span>
                                <% } %>

                                <% if (currUser && currUser._id.equals(review.author._id)) { %>
                                    <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="d-inline">
                                        <button class="review-action-btn text-danger">
                                            <i class="fa-solid fa-trash-can"></i> Delete
                                        </button>
                                    </form>
                                <% } %>
                            </div>

                            <!-- Inline reply box -->
                            <% if (currUser) { %>
                            <div class="inline-reply-box" id="reply-box-<%= review._id %>" style="display:none;">
                                <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>/replies">
                                    <div class="d-flex gap-2 align-items-start">
                                        <div class="reply-avatar-sm"><%= currUser.username.charAt(0).toUpperCase() %></div>
                                        <div class="flex-grow-1">
                                            <textarea name="text" rows="2" class="form-control custom-input reply-textarea"
                                                placeholder="Write a reply..." required maxlength="500"></textarea>
                                            <div class="d-flex gap-2 mt-2">
                                                <button type="submit" class="btn btn-sm btn-teal-solid rounded-pill px-3" data-loading-text="Posting...">Reply</button>
                                                <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill"
                                                    onclick="toggleInlineReply('reply-box-<%= review._id %>')">Cancel</button>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                            </div>
                            <% } %>

                            <!-- Replies thread -->
                            <% if (review.replies && review.replies.length > 0) { %>
                            <div class="replies-thread">
                                <% review.replies.forEach(reply => { %>
                                <div class="reply-item" id="reply-<%= reply._id %>">
                                    <div class="reply-avatar-sm <%= reply.isOwnerReply ? 'owner-avatar' : '' %>">
                                        <%= reply.author ? reply.author.username.charAt(0).toUpperCase() : '?' %>
                                    </div>
                                    <div class="reply-item-body">
                                        <div class="reply-item-header">
                                            <span class="reply-username">@<%= reply.author ? reply.author.username : 'Unknown' %></span>
                                            <% if (reply.isOwnerReply) { %>
                                                <span class="owner-reply-badge"><i class="fa-solid fa-user-tie"></i> Owner</span>
                                            <% } %>
                                            <span class="review-timestamp"><%= new Date(reply.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
                                        </div>
                                        <p class="reply-text"><%= reply.text %></p>
                                        <div class="review-actions">
                                            <% const userLikedReply = currUser && reply.likes.some(id => id.equals(currUser._id)); %>
                                            <% const userDislikedReply = currUser && reply.dislikes.some(id => id.equals(currUser._id)); %>
                                            <% if (currUser) { %>
                                                <button class="review-action-btn like-btn <%= userLikedReply ? 'active-like' : '' %>"
                                                    data-id="<%= review._id %>" data-reply-id="<%= reply._id %>" data-type="reply" data-action="like"
                                                    onclick="toggleVote(this)">
                                                    <i class="fa-<%= userLikedReply ? 'solid' : 'regular' %> fa-thumbs-up"></i>
                                                    <span class="like-count"><%= reply.likes.length %></span>
                                                </button>
                                                <button class="review-action-btn dislike-btn <%= userDislikedReply ? 'active-dislike' : '' %>"
                                                    data-id="<%= review._id %>" data-reply-id="<%= reply._id %>" data-type="reply" data-action="dislike"
                                                    onclick="toggleVote(this)">
                                                    <i class="fa-<%= userDislikedReply ? 'solid' : 'regular' %> fa-thumbs-down"></i>
                                                    <span class="dislike-count"><%= reply.dislikes.length %></span>
                                                </button>
                                            <% } else { %>
                                                <span class="review-vote-count"><i class="fa-regular fa-thumbs-up"></i> <%= reply.likes.length %></span>
                                            <% } %>
                                            <% if (currUser && (reply.author && currUser._id.equals(reply.author._id) || (listing.owner && currUser._id.equals(listing.owner._id)))) { %>
                                                <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>/replies/<%= reply._id %>?_method=DELETE" class="d-inline">
                                                    <button class="review-action-btn text-danger"><i class="fa-solid fa-trash-can"></i></button>
                                                </form>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                                <% }) %>
                            </div>
                            <% } %>

                        </div>
                    </div>
                    <% } %>
                </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<% if (typeof currUser !== 'undefined' && currUser && listing.owner && !listing.owner._id.equals(currUser._id)) { %>
<div class="modal fade" id="bookingModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content booking-modal-content">
      <div class="modal-header border-0">
        <h5 class="modal-title">Request to Book</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form action="/bookings/listing/<%= listing._id %>" method="POST" class="needs-validation" novalidate>
        <div class="modal-body">

          <div class="mb-3">
            <label class="form-label">Price Plan</label>
            <% const bookingPlan = typeof PRICE_PLANS !== 'undefined' ? PRICE_PLANS.find(p => p.key === listing.pricePlan) : null; %>
            <% if (listing.pricePlan === 'free' || listing.pricePlan === 'onetime') { %>
                <input type="hidden" name="booking[billingPlan]" value="<%= listing.pricePlan %>">
                <div class="form-control custom-input" style="background:var(--color-bg-light);">
                    <i class="fa-solid fa-calendar-check me-1 text-muted"></i>
                    <%= bookingPlan ? bookingPlan.label : listing.pricePlan %>
                </div>
            <% } else { %>
                <select name="booking[billingPlan]" class="form-select custom-input" required>
                    <option value="" disabled selected>Choose a plan</option>
                    <% if (typeof PRICE_PLANS !== 'undefined') { %>
                        <% PRICE_PLANS.filter(p => !['free','onetime'].includes(p.key)).forEach(plan => { %>
                            <option value="<%= plan.key %>" <%= listing.pricePlan === plan.key ? 'selected' : '' %>>
                                <%= plan.label %>
                            </option>
                        <% }) %>
                    <% } %>
                </select>
                <div class="invalid-feedback">Please choose a plan</div>
            <% } %>
          </div>

          <div class="mb-3">
            <label class="form-label">Preferred Move-in / Start Date</label>
            <input type="date" name="booking[moveInDate]" class="form-control custom-input" required min="<%= new Date().toISOString().split('T')[0] %>">
            <div class="invalid-feedback">Please select a date</div>
          </div>

          <div class="mb-3">
            <label class="form-label">Message to Owner <span class="text-muted small">(optional)</span></label>
            <textarea name="booking[message]" class="form-control custom-input" rows="3" maxlength="500" placeholder="e.g., Number of people, special requests..."></textarea>
          </div>

          <p class="small text-muted mb-0"><i class="fa-solid fa-circle-info me-1"></i>This sends a request — the owner will confirm or decline. No payment is taken now.</p>
        </div>
        <div class="modal-footer border-0">
          <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-book-now rounded-pill px-4" id="bookingSubmitBtn">
              <i class="fa-solid fa-calendar-check me-2"></i>Send Request
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
<% } %>

<script>
function toggleInlineReply(id) {
    const box = document.getElementById(id);
    if (!box) return;
    const isHidden = box.style.display === 'none';
    box.style.display = isHidden ? 'block' : 'none';
    if (isHidden) box.querySelector('textarea')?.focus();
}

async function toggleVote(btn) {
    const type = btn.dataset.type;     // "review" or "reply"
    const action = btn.dataset.action; // "like" or "dislike"
    const reviewId = btn.dataset.id;
    const replyId = btn.dataset.replyId;

    let url = `/listings/<%= listing._id %>/reviews/${reviewId}`;
    if (type === 'reply') url += `/replies/${replyId}`;
    url += `/${action}`;

    btn.disabled = true;
    try {
        const res = await fetch(url, { method: 'POST' });
        const data = await res.json();

        // Update the containing action group
        const group = btn.closest('.review-actions');

        // Update like button
        const likeBtn = group.querySelector('.like-btn');
        if (likeBtn) {
            likeBtn.querySelector('.like-count').textContent = data.likes;
            const isLiked = action === 'like' && !likeBtn.classList.contains('active-like')
                          || (action === 'like' && likeBtn.classList.toggle('active-like'));
            const icon = likeBtn.querySelector('i');
            likeBtn.classList.toggle('active-like');
            icon.className = likeBtn.classList.contains('active-like') ? 'fa-solid fa-thumbs-up' : 'fa-regular fa-thumbs-up';
            // Remove dislike active if liking
            if (action === 'like') {
                const dislikeBtn = group.querySelector('.dislike-btn');
                if (dislikeBtn) {
                    dislikeBtn.classList.remove('active-dislike');
                    dislikeBtn.querySelector('i').className = 'fa-regular fa-thumbs-down';
                    dislikeBtn.querySelector('.dislike-count').textContent = data.dislikes;
                }
            }
        }

        // Update dislike button
        const dislikeBtn = group.querySelector('.dislike-btn');
        if (dislikeBtn && action === 'dislike') {
            dislikeBtn.querySelector('.dislike-count').textContent = data.dislikes;
            dislikeBtn.classList.toggle('active-dislike');
            dislikeBtn.querySelector('i').className = dislikeBtn.classList.contains('active-dislike') ? 'fa-solid fa-thumbs-down' : 'fa-regular fa-thumbs-down';
            const likeBtn2 = group.querySelector('.like-btn');
            if (likeBtn2) {
                likeBtn2.classList.remove('active-like');
                likeBtn2.querySelector('i').className = 'fa-regular fa-thumbs-up';
                likeBtn2.querySelector('.like-count').textContent = data.likes;
            }
        }
    } catch(e) { console.error(e); }
    finally { btn.disabled = false; }
}
</script>

<script>

// Booking form loading state
document.querySelector('#bookingModal form')?.addEventListener('submit', function(e) {
    if (!this.checkValidity()) return;
    const btn = document.getElementById('bookingSubmitBtn');
    if (!btn) return;
    btn.disabled = true;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-2"></i>Sending...';
});

// Review form loading state
document.querySelector('#reviewForm form')?.addEventListener('submit', function(e) {
    if (!this.checkValidity()) return;
    const btn = document.getElementById('reviewSubmitBtn');
    if (!btn) return;
    btn.disabled = true;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-2"></i>Submitting...';
});
</script>

