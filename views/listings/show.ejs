<% layout("/layouts/boilerplate") %>
<link rel="stylesheet" href="/css/show-ejs.css">
<div class="row mt-3">
    <div class="col-8 offset-2">
        <h3 class="listing-header"><%= listing.title %></h3>
    </div>

    <div class="card col-8 offset-2 show-card listing-card border-0">
        <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_image">
        
        <div class="card-body px-0">
            <p class="owner-tag">Hosted by <b><%= listing.owner.username %></b></p>
            
            <div class="listing-details">
                <p class="description-text"><%= listing.description %></p>
                <hr>
                <div class="price-location-box">
                    <p class="price-tag"><span>&#x20B9;</span> <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %> <small>/ month</small></p>
                    <p class="loc-text"><i class="fa-solid fa-location-dot"></i> <%= listing.location %>, <%= listing.country %></p>
                </div>
            </div>
        </div>
    </div>
    
    <% if(currUser && listing.owner._id.equals(currUser._id)){ %>
    <div class="col-8 offset-2 btns-row">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-edit col-2">Edit Listing</a>
        <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" style="display: inline;">
            <button class="btn btn-delete ms-3">Delete</button>
        </form>
    </div>
    <% } %>

    <div class="col-8 offset-2 mb-3">
        <hr>
        <h4 class="section-title">Where you'll be</h4>
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
        
        <div id="map" class="map-container"></div>

        <script>
            <% if (listing.geometry && listing.geometry.coordinates && listing.geometry.coordinates.length > 0) { %>
                const coordinates = <%- JSON.stringify(listing.geometry.coordinates) %>;
                const map = L.map('map').setView([coordinates[1], coordinates[0]], 14);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
                L.marker([coordinates[1], coordinates[0]]).addTo(map)
                 .bindPopup("<b><%= listing.location %></b>").openPopup();
            <% } else { %>
                document.getElementById('map').innerHTML = "<p class='map-error'>Location coordinates missing. Please update listing.</p>";
            <% } %>
        </script>
    </div>

    <div class="col-8 offset-2 mb-3">
        <% if(currUser) { %>
            <hr>
            <h4 class="section-title">Leave a Review</h4>
            <form action="/listings/<%=listing.id%>/reviews" method="post" novalidate class="needs-validation">
                <div class="mb-3 mt-3">
                    <fieldset class="starability-slot">
                      <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                      <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                      <label for="first-rate1" title="Terrible">1 star</label>
                      <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                      <label for="first-rate2" title="Not good">2 stars</label>
                      <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                      <label for="first-rate3" title="Average">3 stars</label>
                      <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                      <label for="first-rate4" title="Very good">4 stars</label>
                      <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                      <label for="first-rate5" title="Amazing">5 stars</label>
                    </fieldset>
                </div>
                <div class="mb-3 mt-3">
                      <label for="comment" class="form-label">Your experience</label>
                      <textarea name="review[comment]" id="comment" cols="30" rows="4" class="form-control custom-input" required placeholder="Tell other students about the food, wifi, or roommates..."></textarea>
                </div>
                <button class="btn btn-submit">Post Review</button>
            </form>
        <% } %>
            
        <% if(listing.reviews.length > 0) { %>
            <hr>
            <h4 class="section-title">Student Reviews</h4>
            <div class="row mt-3">
                <% for(let review of listing.reviews) { %> 
                <div class="col-lg-5 col-md-6 mb-3">
                    <div class="card review-card h-100">
                        <div class="card-body">
                            <h6 class="review-author">@<%= review.author.username %></h6>
                            <p class="starability-result" data-rating="<%= review.rating %>"></p>
                            <p class="review-text"><%= review.comment %></p>
                            <% if(currUser && review.author._id.equals(currUser._id)) { %>
                            <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                                <button class="btn btn-sm btn-outline-danger border-0">Delete</button>
                            </form>
                            <% } %>
                        </div>
                    </div>
                </div>
                <% } %>
            </div>
        <% } %>
    </div>
</div>