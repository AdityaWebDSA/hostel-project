<% layout("/layouts/boilerplate")%>
<link rel="stylesheet" href="/css/show-ejs.css">

<div class="show-page-wrapper">

    <div class="container pt-3">
        <a href="/listings" class="back-link"><i class="fa-solid fa-arrow-left"></i> Back to listings</a>
    </div>

    <div class="bento-gallery-wrapper mb-4">
        <div class="bento-grid">
            <div class="bento-item main-img">
                <% if (listing.image && listing.image.length > 0) { %>
                    <img src="<%= detailImage(listing.image[0].url) %>" id="mainDisplayImg" alt="Main Image">
                <% } else { %>
                    <img src="https://images.unsplash.com/photo-1522708323590-d24dbb6b0267" id="mainDisplayImg" alt="Default Image">
                <% } %>
            </div>

            <div class="side-grid">
                <% for(let i = 1; i < 5; i++) { %>
                    <div class="bento-item small-img">
                        <% if (listing.image && listing.image[i]) { %>
                            <img src="<%= smallThumb(listing.image[i].url) %>" data-full="<%= detailImage(listing.image[i].url) %>" onclick="swapImage(this.dataset.full)" class="clickable-thumb" alt="Room View">
                        <% } else { %>
                            <div class="img-placeholder d-flex align-items-center justify-content-center">
                                <i class="fa-solid fa-camera text-muted"></i>
                            </div>
                        <% } %>

                        <% if (listing.image && i === 4 && listing.image.length > 5) { %>
                            <div class="show-all-overlay">
                                <span>+<%= listing.image.length - 5 %> Photos</span>
                            </div>
                        <% } %>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <div class="container mt-4">

        <div class="listing-header mb-4">
            <h2 class="listing-show-title"><%= listing.title %></h2>
            <p class="listing-show-location">
                <i class="fa-solid fa-location-dot"></i>
                <%= listing.landmark ? listing.landmark + ", " : "" %><%= listing.location %><%= listing.country ? ", " + listing.country : "" %>
            </p>
        </div>

        <% if (listing.category && listing.category.length > 0) { %>
            <div class="category-pills-show mb-4">
                <% listing.category.forEach(catKey => {
                    const cat = CATEGORIES.find(c => c.key === catKey);
                    if (cat) { %>
                        <span class="category-pill-lg"><i class="<%= cat.icon %>"></i> <%= cat.label %></span>
                    <% }
                }) %>
            </div>
        <% } %>

        <div class="row gx-lg-5">
            <div class="col-lg-8">
                <div class="host-info-card d-flex align-items-center p-3 mb-4">
                    <div class="user-avatar">
                        <%= listing.owner && listing.owner.username ? listing.owner.username.charAt(0).toUpperCase() : "?" %>
                    </div>
                    <div class="ms-3">
                        <h6 class="mb-0 host-name">Hosted by <%= listing.owner ? listing.owner.username : "Unknown" %></h6>
                        <small class="text-muted">Verified Owner</small>
                    </div>
                </div>

                <div class="description-section mb-5">
                    <h4 class="section-label">About this place</h4>
                    <p class="description-body"><%= listing.description %></p>
                </div>

             <% if ((listing.amenities && listing.amenities.length > 0) || listing.customAmenities) { %>
                <div class="amenities-grid mb-5">
                    <h4 class="section-label">What to expect</h4>
                    <div class="row g-3">
                        <% if (listing.amenities && listing.amenities.length > 0) { %>
                            <% listing.amenities.forEach(key => {
                                const amenity = ALL_AMENITIES[key];
                                if (amenity) { %>
                                    <div class="col-6 col-md-4 amenity-item">
                                        <i class="<%= amenity.icon %>"></i> <%= amenity.label %>
                                    </div>
                                <% }
                            }) %>
                        <% } %>
                        <% if (listing.customAmenities) {
                            listing.customAmenities.split(',').map(s => s.trim()).filter(Boolean).forEach(item => { %>
                                <div class="col-6 col-md-4 amenity-item">
                                    <i class="fa-solid fa-circle-check"></i> <%= item %>
                                </div>
                            <% })
                        } %>
                    </div>
                </div>
                <% } %>

                <% if(currUser && listing.owner && currUser._id.equals(listing.owner._id)) { %>
                    <div class="owner-actions p-4 rounded-4 d-flex gap-3">
                        <a href="/listings/<%= listing._id %>/edit" class="btn btn-edit-premium flex-grow-1">
                            <i class="fa-solid fa-sliders me-2"></i>Manage Listing
                        </a>
                        <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="flex-grow-1">
                            <button class="btn btn-delete-premium w-100">
                                <i class="fa-solid fa-trash-can me-2"></i>Remove
                            </button>
                        </form>
                    </div>
                <% } %>
            </div>

            <div class="col-lg-4">
                <div class="booking-card sticky-top shadow-lg">
                    <div class="price-header d-flex justify-content-between align-items-center">
                        <div>
                            <% if (listing.price && listing.price > 0) { %>
                                <span class="price-big">&#x20B9;<%= listing.price.toLocaleString("en-IN") %></span>
                                <% const activePlan = PRICE_PLANS.find(p => p.key === listing.pricePlan); %>
                                <span class="text-muted"><%= activePlan ? activePlan.label : '/month' %></span>
                            <% } else { %>
                                <span class="price-big price-free">Free / Enquire</span>
                            <% } %>
                        </div>
                        <div class="rating-badge">
                            <i class="fa-solid fa-star"></i>
                            <% if (reviewCount > 0) { %>
                                <%= avgRating %> <span class="review-count">(<%= reviewCount %>)</span>
                            <% } else { %>
                                New
                            <% } %>
                        </div>
                    </div>
                    <hr>
             <div class="booking-details mb-4">
                        <% if (listing.pricePlan) { 
                            const plan = PRICE_PLANS.find(p => p.key === listing.pricePlan); %>
                            <div class="billing-pills">
                                <span class="billing-pill">
                                    <i class="fa-solid fa-calendar-check"></i>
                                    <%= plan ? plan.label : listing.pricePlan %>
                                </span>
                            </div>
                        <% } %>
                        <p class="mb-0 mt-2"><i class="fa-solid fa-check text-success me-1"></i>Refundable deposit</p>
                    </div>
                    <% if (currUser) { %>
                        <button type="button" class="btn btn-save-listing w-100 mb-2" data-listing-id="<%= listing._id %>" onclick="toggleSave(this)">
                            <i class="<%= isSaved ? 'fa-solid fa-heart saved' : 'fa-regular fa-heart' %>"></i>
                            <span><%= isSaved ? 'Saved' : 'Save to Wishlist' %></span>
                        </button>

                        <% if (!listing.owner._id.equals(currUser._id)) { %>
                            <button type="button" class="btn btn-book-now w-100 mb-3 py-3" data-bs-toggle="modal" data-bs-target="#bookingModal">
                                Request to Book
                            </button>
                            <p class="text-center small text-muted mb-0">You won't be charged yet</p>
                        <% } else { %>
                            <p class="text-center small text-muted mb-0 mt-2">This is your own listing</p>
                        <% } %>
                    <% } else { %>
                        <a href="/login" class="btn btn-book-now w-100 mb-3 py-3 d-block text-center text-decoration-none">Log in to Book</a>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="row mt-5 pt-5 border-top">
            <div class="col-12 mb-4">
                <h4 class="section-label mb-4">Where you'll be staying</h4>
            </div>

            <div class="col-lg-5 mb-4 mb-lg-0">
                <div class="location-info-card">
                    <h6 class="location-card-title"><i class="fa-solid fa-location-dot"></i> Address</h6>
                    <p class="location-address">
                        <%= listing.landmark ? listing.landmark + ", " : "" %><%= listing.location %><%= listing.country ? ", " + listing.country : "" %>
                    </p>

                    <% if (listing.geometry && listing.geometry.coordinates) { %>
                        <a href="https://www.google.com/maps/dir/?api=1&destination=<%= listing.geometry.coordinates[1] %>,<%= listing.geometry.coordinates[0] %>"
                           target="_blank" rel="noopener" class="contact-action-btn directions-btn">
                            <i class="fa-solid fa-diamond-turn-right"></i> Get Directions
                        </a>
                    <% } %>

                    <hr class="my-4">

                    <h6 class="location-card-title"><i class="fa-solid fa-address-card"></i> Contact</h6>

                    <% if (listing.contactNumber || listing.contactEmail) { %>
                        <div class="contact-actions">
                            <% if (listing.contactNumber) { %>
                                <a href="tel:<%= listing.contactNumber %>" class="contact-action-btn">
                                    <i class="fa-solid fa-phone"></i> Call <%= listing.contactNumber %>
                                </a>
                                <a href="https://wa.me/<%= listing.contactNumber.replace(/[^0-9]/g, '') %>" target="_blank" rel="noopener" class="contact-action-btn whatsapp-btn">
                                    <i class="fa-brands fa-whatsapp"></i> WhatsApp
                                </a>
                            <% } %>
                            <% if (listing.contactEmail) { %>
                                <a href="mailto:<%= listing.contactEmail %>" class="contact-action-btn email-btn">
                                    <i class="fa-solid fa-envelope"></i> Email
                                </a>
                            <% } %>
                        </div>
                    <% } else { %>
                        <p class="text-muted small mb-0">The owner hasn't added contact details yet.</p>
                    <% } %>
                </div>
            </div>

            <div class="col-lg-7">
                <div id="map" class="map-premium"></div>
            </div>

            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="section-label">
                        Reviews (<%= listing.reviews.length %>)
                        <% if (reviewCount > 0) { %>
                            <span class="reviews-avg"><i class="fa-solid fa-star"></i> <%= avgRating %></span>
                        <% } %>
                    </h4>
                    <% if(currUser) { %>
                        <button class="btn btn-outline-teal rounded-pill" data-bs-toggle="collapse" data-bs-target="#reviewForm">
                            Write a Review
                        </button>
                    <% } %>
                </div>

                <div class="collapse mb-5" id="reviewForm">
                    <div class="card card-body border-0 shadow-sm rounded-4 p-4">
                        <h5 class="mb-3">Share your experience</h5>
                        <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
                            <div class="mb-3">
                                <label class="form-label">Rating</label>
                                <fieldset class="starability-slot">
                                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                                    <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                    <label for="first-rate1" title="Terrible">1 star</label>
                                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                    <label for="first-rate2" title="Not good">2 stars</label>
                                    <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                    <label for="first-rate3" title="Average">3 stars</label>
                                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                    <label for="first-rate4" title="Very good">4 stars</label>
                                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                    <label for="first-rate5" title="Amazing">5 stars</label>
                                </fieldset>
                            </div>

                            <div class="mb-3">
                                <label for="comment" class="form-label">Comment</label>
                                <textarea name="review[comment]" id="comment" cols="30" rows="4" class="form-control custom-input" required placeholder="Tell us about the hostel, mess, or owner..."></textarea>
                                <div class="invalid-feedback">Please add a comment before submitting.</div>
                            </div>

                            <button class="btn btn-teal-solid px-5 rounded-pill">Submit Review</button>
                        </form>
                    </div>
                </div>

                <% if (listing.reviews.length === 0) { %>
                    <div class="no-reviews-yet">
                        <i class="fa-regular fa-comment-dots"></i>
                        <p class="mb-0">No reviews yet. Be the first to share your experience!</p>
                    </div>
                <% } else { %>
                <div class="row g-4">
                    <% for(let review of listing.reviews) { %>
                        <div class="col-md-6">
                            <div class="review-card-modern p-4 h-100">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="mb-0 review-author">@<%= review.author.username %></h6>
                                    <p class="starability-result" data-rating="<%= review.rating %>"></p>
                                </div>
                                <p class="review-text">"<%= review.comment %>"</p>

                                <% if(currUser && currUser._id.equals(review.author._id)) { %>
                                    <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                                        <button class="btn btn-sm btn-outline-danger border-0 mt-2">
                                            <i class="fa-solid fa-trash-can me-1"></i>Delete Review
                                        </button>
                                    </form>
                                <% } %>
                            </div>
                        </div>
                    <% } %>
                </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- Booking Request Modal -->
<% if (currUser && listing.owner && !listing.owner._id.equals(currUser._id)) { %>
<div class="modal fade" id="bookingModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content booking-modal-content">
      <div class="modal-header border-0">
        <h5 class="modal-title">Request to Book</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form action="/bookings/listing/<%= listing._id %>" method="POST" class="needs-validation" novalidate>
        <div class="modal-body">

         <div class="mb-3">
            <label class="form-label">Price Plan</label>
            <% const bookingPlan = PRICE_PLANS.find(p => p.key === listing.pricePlan); %>
            <% if (listing.pricePlan === 'free' || listing.pricePlan === 'onetime') { %>
                <input type="hidden" name="booking[billingPlan]" value="<%= listing.pricePlan %>">
                <div class="form-control custom-input" style="background:var(--color-bg-light);">
                    <i class="fa-solid fa-calendar-check me-1 text-muted"></i>
                    <%= bookingPlan ? bookingPlan.label : listing.pricePlan %>
                </div>
            <% } else { %>
                <select name="booking[billingPlan]" class="form-select custom-input" required>
                    <option value="" disabled selected>Choose a plan</option>
                    <% PRICE_PLANS.filter(p => !['free','onetime'].includes(p.key)).forEach(plan => { %>
                        <option value="<%= plan.key %>" <%= listing.pricePlan === plan.key ? 'selected' : '' %>>
                            <%= plan.label %>
                        </option>
                    <% }) %>
                </select>
                <div class="invalid-feedback">Please choose a plan</div>
            <% } %>
          </div>

          <div class="mb-3">
            <label class="form-label">Preferred Move-in / Start Date</label>
            <input type="date" name="booking[moveInDate]" class="form-control custom-input" required min="<%= new Date().toISOString().split('T')[0] %>">
            <div class="invalid-feedback">Please select a date</div>
          </div>

          <div class="mb-3">
            <label class="form-label">Message to Owner <span class="text-muted small">(optional)</span></label>
            <textarea name="booking[message]" class="form-control custom-input" rows="3" maxlength="500" placeholder="e.g., Number of people, special requests..."></textarea>
          </div>

          <p class="small text-muted mb-0"><i class="fa-solid fa-circle-info me-1"></i>This sends a request — the owner will confirm or decline. No payment is taken now.</p>
        </div>
        <div class="modal-footer border-0">
          <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-book-now rounded-pill px-4">Send Request</button>
        </div>
      </form>
    </div>
  </div>
</div>
<% } %>

<script>
    function swapImage(newSrc) {
        const mainImg = document.getElementById('mainDisplayImg');
        mainImg.style.opacity = '0.4';
        setTimeout(() => {
            mainImg.src = newSrc;
            mainImg.style.opacity = '1';
        }, 150);
    }
</script>
<script>
    const mapKey = "<%= process.env.LOCATION_IQ_KEY %>";
    const listing = <%- JSON.stringify(listing) %>;
</script>
<script src="/js/map.js"></script>