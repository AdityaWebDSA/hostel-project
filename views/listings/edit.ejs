<% layout("/layouts/boilerplate") %>
<link rel="stylesheet" href="/css/edit-ejs.css">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<div class="row mt-4 mb-5">
    <div class="col-8 offset-2">
        <h3 class="page-heading">Edit Your Listing</h3>
        
        <div class="form-container">
            <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" class="needs-validation" novalidate enctype="multipart/form-data">

                <div class="mb-3">
                    <label class="form-label">Title</label>
                    <input name="listing[title]" value="<%= listing.title %>" type="text" class="form-control custom-input" required>
                    <div class="invalid-feedback">Title is Required</div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea name="listing[description]" class="form-control custom-input" rows="4" required><%= listing.description %></textarea>
                    <div class="invalid-feedback">Please enter a short description</div>
                </div>

                <!-- Categories -->
                <div class="mb-3 category-group">
                    <label class="form-label">What does this place offer?</label>
                    <div class="category-grid">
                        <% CATEGORIES.forEach(cat => { %>
                            <div class="category-option">
                                <input type="checkbox" name="listing[category][]" value="<%= cat.key %>" id="cat-<%= cat.key %>" class="category-checkbox"
                                    <%= (listing.category && listing.category.includes(cat.key)) ? "checked" : "" %>>
                                <label for="cat-<%= cat.key %>" class="category-label">
                                    <i class="<%= cat.icon %>"></i>
                                    <span><%= cat.label %></span>
                                </label>
                            </div>
                        <% }) %>
                    </div>
                    <input type="text" class="form-control category-validity" required>
                    <div class="invalid-feedback">Please select at least one category</div>
                    <div class="mb-3" id="genderPolicySection" style="display:none;">
                    <label class="form-label">Who is this for?</label>
                    <div class="gender-options">
                        <div class="gender-option">
                            <input type="radio" name="listing[genderPolicy]" value="boys" id="gender-boys" class="gender-radio"
                                <%= listing.genderPolicy === 'boys' ? 'checked' : '' %>>
                            <label for="gender-boys" class="gender-label">
                                <i class="fa-solid fa-mars"></i> Boys Only
                            </label>
                        </div>
                        <div class="gender-option">
                            <input type="radio" name="listing[genderPolicy]" value="girls" id="gender-girls" class="gender-radio"
                                <%= listing.genderPolicy === 'girls' ? 'checked' : '' %>>
                            <label for="gender-girls" class="gender-label">
                                <i class="fa-solid fa-venus"></i> Girls Only
                            </label>
                        </div>
                        <div class="gender-option">
                            <input type="radio" name="listing[genderPolicy]" value="coed" id="gender-coed" class="gender-radio"
                                <%= listing.genderPolicy === 'coed' || !listing.genderPolicy ? 'checked' : '' %>>
                            <label for="gender-coed" class="gender-label">
                                <i class="fa-solid fa-venus-mars"></i> Co-ed / All
                            </label>
                        </div>
                    </div>
                    <small class="text-muted">Leave unselected if not applicable</small>
                </div>
                </div>

                <!-- Images -->
                <div class="mb-3">
                    <label class="form-label">Current Images (Select to Delete)</label>
                    <div class="row row-cols-md-4 row-cols-2 g-3 mb-3">
                        <% if (listing.image && listing.image.length > 0) { %>
                            <% listing.image.forEach((img, index) => { %>
                                <div class="col">
                                    <div class="edit-img-container">
                                        <img src="<%= img.url.replace('/upload', '/upload/w_200,h_200,c_fill') %>" class="img-thumbnail rounded-3" alt="listing_img">
                                        <div class="delete-overlay">
                                            <input type="checkbox" name="deleteImages[]" value="<%= img.filename %>" id="del-<%= index %>" class="delete-checkbox">
                                            <label for="del-<%= index %>" class="delete-icon-label"><i class="fa-solid fa-trash-can"></i></label>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        <% } %>
                    </div>
                    <label class="form-label">Add More Images</label>
                    <input name="listing[image]" type="file" class="form-control custom-input" multiple>
                </div>

                <!-- Price + Plan inline -->
                <div class="mb-3">
                    <label class="form-label">Price & Plan</label>
                    <div class="price-plan-row">
                        <div class="price-plan-prefix">₹</div>
                        <input name="listing[price]" value="<%= listing.price %>" type="number" class="form-control custom-input price-plan-input" min="0">
                        <select name="listing[pricePlan]" class="form-select custom-input price-plan-select">
                            <% PRICE_PLANS.forEach(plan => { %>
                                <option value="<%= plan.key %>" <%= listing.pricePlan === plan.key ? 'selected' : '' %>><%= plan.label %></option>
                            <% }) %>
                        </select>
                    </div>
                </div>

                <!-- Dynamic Amenities (pre-loaded from existing data) -->
                <div class="mb-3" id="amenitiesSection" style="<%= (listing.category && listing.category.length > 0) ? '' : 'display:none;' %>">
                    <label class="form-label">What's available here?</label>
                    <div class="amenity-grid" id="amenityGrid"></div>
                    <div class="mt-3">
                        <label class="form-label">Anything else? <span class="text-muted small">(optional)</span></label>
                        <input type="text" name="listing[customAmenities]" class="form-control custom-input" value="<%= listing.customAmenities || '' %>" placeholder="e.g. Hot water, Rooftop access...">
                    </div>
                </div>

                <!-- Location -->
                <div class="row">
                    <div class="mb-3 col-md-8">
                        <label class="form-label">City/Location</label>
                        <input name="listing[location]" id="locationInput" value="<%= listing.location %>" type="text" class="form-control custom-input" required>
                        <div class="invalid-feedback">Location should be valid</div>
                    </div>
                    <div class="mb-3 col-md-4">
                        <label class="form-label">Country</label>
                        <input name="listing[country]" value="<%= listing.country %>" type="text" class="form-control custom-input" required>
                        <div class="invalid-feedback">Country is required</div>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Exact Landmark / Street</label>
                    <input name="listing[landmark]" value="<%= listing.landmark || '' %>" placeholder="e.g., Near Bharati Vidyapeeth College" type="text" class="form-control custom-input">
                </div>

                <!-- Map picker -->
                <div class="mb-3">
                    <label class="form-label">Pin Exact Location <span class="text-muted small">(click/drag to update)</span></label>
                    <div id="locationPickerMap" class="location-picker-map"></div>
                    <div class="map-helper-row">
                        <button type="button" id="locateMeBtn" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                            <i class="fa-solid fa-location-crosshairs me-1"></i> Re-search
                        </button>
                        <span id="pinStatus" class="text-muted small">Showing current saved location.</span>
                    </div>
                    <input type="hidden" name="listing[lat]" id="latInput" value="<%= (listing.geometry && listing.geometry.coordinates) ? listing.geometry.coordinates[1] : '' %>">
                    <input type="hidden" name="listing[lng]" id="lngInput" value="<%= (listing.geometry && listing.geometry.coordinates) ? listing.geometry.coordinates[0] : '' %>">
                </div>

                <!-- Contact -->
                <div class="row">
                    <div class="mb-3 col-md-6">
                        <label class="form-label">Contact Number</label>
                        <input name="listing[contactNumber]" value="<%= listing.contactNumber || '' %>" type="tel" class="form-control custom-input">
                    </div>
                    <div class="mb-3 col-md-6">
                        <label class="form-label">Contact Email</label>
                        <input name="listing[contactEmail]" value="<%= listing.contactEmail || '' %>" type="email" class="form-control custom-input">
                    </div>
                </div>

                <div class="d-grid gap-2 d-md-flex justify-content-md-start mt-4">
                    <button class="btn edit-btn px-5 py-2">Update Listing</button>
                    <a href="/listings/<%= listing._id %>" class="btn btn-outline-secondary px-4 py-2">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
const AMENITY_MAP = <%- JSON.stringify(AMENITY_MAP) %>;
const EXISTING_AMENITIES = <%- JSON.stringify(listing.amenities || []) %>;

function buildAmenityGrid(selectedCategories, currentlyChecked = []) {
    const section = document.getElementById('amenitiesSection');
    const grid = document.getElementById('amenityGrid');
    const seen = new Set();
    const amenities = [];
    for (const cat of selectedCategories) {
        const list = AMENITY_MAP[cat] || [];
        for (const a of list) {
            if (!seen.has(a.key)) { seen.add(a.key); amenities.push(a); }
        }
    }
    if (amenities.length === 0) { section.style.display = 'none'; return; }
    section.style.display = '';
    grid.innerHTML = amenities.map(a => `
        <div class="amenity-option">
            <input type="checkbox" name="listing[amenities][]" value="${a.key}" id="am-${a.key}" class="amenity-checkbox" ${currentlyChecked.includes(a.key) ? 'checked' : ''}>
            <label for="am-${a.key}" class="amenity-label"><i class="${a.icon}"></i><span>${a.label}</span></label>
        </div>
    `).join('');
}

// Load amenity grid on page load from existing categories
const initialCategories = Array.from(document.querySelectorAll('.category-checkbox:checked')).map(c => c.value);
buildAmenityGrid(initialCategories, EXISTING_AMENITIES);

// Rebuild when categories change
document.querySelectorAll('.category-checkbox').forEach(cb => {
    cb.addEventListener('change', () => {
        const selected = Array.from(document.querySelectorAll('.category-checkbox:checked')).map(c => c.value);
        buildAmenityGrid(selected, EXISTING_AMENITIES);
    });
});
</script>

<script>
(function() {
    const existingLat = parseFloat(document.getElementById('latInput').value);
    const existingLng = parseFloat(document.getElementById('lngInput').value);
    const hasExisting = !isNaN(existingLat) && !isNaN(existingLng);
    const map = L.map('locationPickerMap').setView(hasExisting ? [existingLat, existingLng] : [20.5937, 78.9629], hasExisting ? 15 : 5);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '&copy; OpenStreetMap contributors' }).addTo(map);

    let marker = null;
    const latInput = document.getElementById('latInput');
    const lngInput = document.getElementById('lngInput');
    const pinStatus = document.getElementById('pinStatus');

    function setPin(lat, lng, zoom) {
        latInput.value = lat; lngInput.value = lng;
        if (marker) { marker.setLatLng([lat, lng]); } else {
            marker = L.marker([lat, lng], { draggable: true }).addTo(map);
            marker.on('dragend', () => { const p = marker.getLatLng(); latInput.value = p.lat; lngInput.value = p.lng; pinStatus.textContent = `Pin set at ${p.lat.toFixed(5)}, ${p.lng.toFixed(5)}`; });
        }
        map.setView([lat, lng], zoom || map.getZoom());
        pinStatus.textContent = `Pin set at ${lat.toFixed(5)}, ${lng.toFixed(5)}`;
    }

    if (hasExisting) setPin(existingLat, existingLng, 15);
    map.on('click', e => setPin(e.latlng.lat, e.latlng.lng, Math.max(map.getZoom(), 15)));

    document.getElementById('locateMeBtn').addEventListener('click', async () => {
        const loc = document.getElementById('locationInput').value.trim();
        const lm = document.querySelector('[name="listing[landmark]"]').value.trim();
        const q = lm ? `${lm}, ${loc}` : loc;
        if (!q) return;
        pinStatus.textContent = "Searching...";
        try {
            const res = await fetch(`/listings/geocode-preview?q=${encodeURIComponent(q)}`);
            const data = await res.json();
            if (data.lat) setPin(data.lat, data.lng, 15);
        } catch {}
    });

    setTimeout(() => map.invalidateSize(), 200);
})();
</script>