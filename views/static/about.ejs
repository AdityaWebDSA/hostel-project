<% layout("/layouts/boilerplate")%>
<link rel="stylesheet" href="/css/static-pages.css">

<div class="index-container static-page">
    <h2 class="page-heading">About UniNest</h2>
    <p class="static-lead">UniNest helps students find everything around their campus — not just a place to stay, but the everyday essentials around it.</p>

    <div class="about-grid">
        <div class="about-card">
            <i class="fa-solid fa-house-user"></i>
            <h5>Housing</h5>
            <p>Hostels, PGs, and independent rooms near your college, listed by real owners.</p>
        </div>
        <div class="about-card">
            <i class="fa-solid fa-map-location-dot"></i>
            <h5>Nearby Essentials</h5>
            <p>Mess, laundry, gyms, clinics, Xerox shops, and cafes — all in one searchable map.</p>
        </div>
        <div class="about-card">
            <i class="fa-solid fa-handshake"></i>
            <h5>Direct Connection</h5>
            <p>Message or call owners directly, send booking requests, and manage everything from your dashboard.</p>
        </div>
    </div>

    <p class="static-footer-note">Built by students, for students.</p>
</div>