        <div class="nav-divider d-none d-md-block"></div>

        <% if(!locals.currUser) { %>
          <a class="nav-link auth-link ms-2" href="/signup">Sign up</a>
          <a class="nav-link auth-link-bold ms-2" href="/login">Log in</a>
        <% } %>

        <% if(locals.currUser) { %> 
