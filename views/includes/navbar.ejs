<link rel="stylesheet" href="/css/navbar.css">
<%
  const navUser = typeof currUser !== "undefined" ? currUser : null;
  const navUnreadNotifCount = typeof unreadNotifCount !== "undefined" ? unreadNotifCount : 0;
%>
<nav class="navbar navbar-expand border-bottom sticky-top main-nav">
  <div class="container-fluid px-2 px-md-5 d-flex align-items-center">
    <a class="navbar-brand d-flex align-items-center me-2 me-md-4" href="/listings">
      <div class="brand-logo">
        <img src="/ui_material/main_logo.png" alt="Logo">
      </div>
      <span class="brand-text d-none d-lg-inline ms-2">UniNest</span>
    </a>

    <div class="d-flex align-items-center me-auto primary-links">
      <a class="nav-link custom-nav-link" href="/listings">
        <i class="fa-solid fa-house-user"></i>
        <span class="ms-1 d-none d-md-inline">Home</span>
      </a>

      <% if (navUser) { %>
        <div class="nav-item dropdown">
          <a class="nav-link custom-nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
            <i class="fa-solid fa-calendar-days"></i>
            <span class="ms-1 d-none d-md-inline">Bookings</span>
          </a>
          <ul class="dropdown-menu shadow-sm border-0">
            <li><a class="dropdown-item py-2" href="/bookings"><i class="fa-solid fa-clipboard-list me-2"></i> My Requests</a></li>
            <li><a class="dropdown-item py-2" href="/bookings/received"><i class="fa-solid fa-inbox me-2"></i> Requests Received</a></li>
          </ul>
        </div>

        <a class="nav-link custom-nav-link" href="/saved">
          <i class="fa-solid fa-heart"></i>
          <span class="ms-1 d-none d-md-inline">Saved</span>
        </a>
      <% } %>
    </div>

    <div class="navbar-nav mx-auto search-container">
      <form class="d-flex search-form" role="search" action="/listings/search" method="GET">
        <input name="q" class="form-control search-input" type="search" placeholder="Search your area..." aria-label="Search">
        <button class="btn search-btn" type="submit" id="searchSubmitBtn">
          <i class="fa-solid fa-magnifying-glass" id="searchBtnIcon"></i>
        </button>
      </form>
    </div>

    <div class="navbar-nav ms-auto align-items-center flex-row">
      <% if (navUser) { %>
        <a class="nav-link add-listing-btn me-2 me-md-3" href="/listings/new">
          <i class="fa-solid fa-plus-circle"></i>
          <span class="ms-1 d-none d-sm-inline">Add Listing</span>
        </a>

        <div class="nav-item dropdown me-1">
          <a class="nav-link notif-bell-link" href="#" role="button" data-bs-toggle="dropdown" id="notifBellToggle">
            <i class="fa-solid fa-bell"></i>
            <% if (navUnreadNotifCount > 0) { %>
              <span class="notif-badge" id="notifBadge"><%= navUnreadNotifCount > 9 ? "9+" : navUnreadNotifCount %></span>
            <% } %>
          </a>
          <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 notif-dropdown-menu">
            <li class="dropdown-header d-flex justify-content-between align-items-center">
              <span>Notifications</span>
              <a href="/notifications" class="see-all-link">See all</a>
            </li>
            <li><hr class="dropdown-divider"></li>
            <li id="notifDropdownContent" class="notif-dropdown-loading">
              <span class="dropdown-item-text text-muted small">Loading...</span>
            </li>
          </ul>
        </div>
      <% } %>

      <div class="nav-divider d-none d-md-block"></div>

      <% if (!navUser) { %>
        <a class="nav-link auth-link d-none d-sm-inline ms-1" href="/signup">Sign up</a>
        <a class="nav-link auth-link-bold ms-1 p-1 p-md-2" href="/login">
          <span class="d-none d-sm-inline">Log in</span>
          <i class="fa-solid fa-right-to-bracket d-inline d-sm-none"></i>
        </a>
      <% } %>

      <% if (navUser) { %>
        <div class="nav-item dropdown ms-1">
          <a class="nav-link dropdown-toggle user-profile-toggle p-1 p-md-2" href="#" role="button" data-bs-toggle="dropdown">
            <% if (navUser.avatar && navUser.avatar.url) { %>
              <img src="<%= navUser.avatar.url %>" class="navbar-avatar-thumb" alt="">
            <% } else { %>
              <i class="fa-regular fa-circle-user"></i>
            <% } %>
            <span class="d-none d-lg-inline ms-1"><%= navUser.username %></span>
          </a>
          <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
            <li><a class="dropdown-item py-2" href="/profile"><i class="fa-solid fa-user me-2"></i> Profile</a></li>
            <li><a class="dropdown-item py-2" href="/listings/mylisting"><i class="fa-solid fa-list-ul me-2"></i> My Listings</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item py-2" href="/help"><i class="fa-solid fa-circle-question me-2"></i> Help &amp; FAQ</a></li>
            <li><a class="dropdown-item py-2" href="/about"><i class="fa-solid fa-circle-info me-2"></i> About Us</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item py-2 text-danger" href="/logout"><i class="fa-solid fa-right-from-bracket me-2"></i> Log out</a></li>
          </ul>
        </div>
      <% } %>
    </div>
  </div>

  <script>
document.querySelector('.search-form')?.addEventListener('submit', function() {
    const btn = document.getElementById('searchSubmitBtn');
    const icon = document.getElementById('searchBtnIcon');
    if (!btn || !icon) return;
    icon.className = 'fa-solid fa-spinner fa-spin';
    btn.disabled = true;
    btn.style.opacity = '0.8';
});
  </script>
</nav>
