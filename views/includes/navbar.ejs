        </a>
        <div class="nav-item dropdown">
          <a class="nav-link dropdown-toggle nav-hover" href="#" role="button" data-bs-toggle="dropdown">
            <i class="fa-solid fa-gears me-1"></i>Services
          </a>
          <ul class="dropdown-menu shadow-sm border-0">
            <li><a class="dropdown-item" href="#"><i class="fa-solid fa-print me-2"></i>Xerox & Stationery</a></li>
            <li><a class="dropdown-item" href="#"><i class="fa-solid fa-kit-medical me-2"></i>Medical Clinics</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="#"><i class="fa-solid fa-circle-info me-2"></i>About UniNest</a></li>
          </ul>
        </div>
      </div>

      <div class="navbar-nav mx-auto search-container">
        <form class="d-flex search-form" role="search">
          <input class="form-control search-input" type="search" placeholder="Search hostels, PGs, or services..." aria-label="Search">
          <button class="btn search-btn" type="submit"><i class="fa-solid fa-magnifying-glass"></i></button>
        </form>
      </div>

