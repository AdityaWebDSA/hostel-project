<link rel="stylesheet" href="/css/footer.css">
<footer class="footer mt-5">
    <div class="container py-5">
        <div class="row gy-4">

            <div class="col-lg-4 col-md-6">
                <div class="footer-brand d-flex align-items-center mb-3">
                    <div class="footer-logo">
                        <img src="/ui_material/main_logo.png" alt="UniNest Logo">
                    </div>
                    <span class="ms-2 footer-brand-text">UniNest</span>
                </div>
                <p class="footer-description pe-lg-5">
                    Connecting students with hostels, PGs, and campus essentials — all in one place.
                </p>
                <div class="f-info-socials">
                    <a href="#" aria-label="Facebook"><i class="fa-brands fa-facebook-f"></i></a>
                    <a href="#" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
                    <a href="#" aria-label="YouTube"><i class="fa-brands fa-youtube"></i></a>
                    <a href="#" aria-label="X/Twitter"><i class="fa-brands fa-x-twitter"></i></a>
                    <a href="#" aria-label="LinkedIn"><i class="fa-brands fa-linkedin-in"></i></a>
                </div>
            </div>

            <div class="col-lg-2 col-md-6">
                <h5 class="footer-heading mb-3">Explore</h5>
                <ul class="list-unstyled footer-links">
                    <li><a href="/listings">All Listings</a></li>
                    <li><a href="/listings?category=hostels-pgs">Hostels & PGs</a></li>
                    <li><a href="/listings?category=mess-tiffins">Mess & Tiffins</a></li>
                    <li><a href="/listings?category=gym-fitness">Gym & Fitness</a></li>
                    <li><a href="/listings?category=cafes-chai">Cafes & Chai</a></li>
                </ul>
            </div>

            <div class="col-lg-2 col-md-6">
                <h5 class="footer-heading mb-3">Support</h5>
                <ul class="list-unstyled footer-links">
                    <li><a href="/help">Help & FAQ</a></li>
                    <li><a href="/about">About UniNest</a></li>
                    <li><a href="/listings/new">List Your Place</a></li>
                    <% if (typeof currUser !== 'undefined' && currUser) { %>
                        <li><a href="/profile">My Profile</a></li>
                        <li><a href="/bookings">My Bookings</a></li>
                    <% } else { %>
                        <li><a href="/signup">Sign Up Free</a></li>
                        <li><a href="/login">Log In</a></li>
                    <% } %>
                </ul>
            </div>

            <div class="col-lg-4 col-md-6">
                <h5 class="footer-heading mb-3">Stay Updated</h5>
                <p class="footer-description">Get new listings and student deals in your inbox.</p>
                <form class="footer-newsletter d-flex gap-2" id="newsletterForm" novalidate>
                    <input type="email" class="form-control" id="newsletterEmail" placeholder="your@email.com" required>
                    <button class="btn footer-btn" type="submit">Join</button>
                </form>
                <small id="newsletterMsg" class="mt-2 d-block" style="min-height:1.2rem;"></small>

                <div class="footer-badges mt-4">
                    <span class="footer-badge"><i class="fa-solid fa-shield-halved"></i> Verified Listings</span>
                    <span class="footer-badge"><i class="fa-solid fa-bolt"></i> Student First</span>
                </div>
            </div>
        </div>

        <hr class="my-4 footer-divider">

        <div class="row align-items-center">
            <div class="col-md-6 text-center text-md-start">
                <div class="f-info-brand">&copy; <%= new Date().getFullYear() %> UniNest. All rights reserved.</div>
            </div>
            <div class="col-md-6 text-center text-md-end mt-2 mt-md-0">
                <div class="f-info-links">
                    <a href="/help" class="me-3">Help</a>
                    <a href="/about" class="me-3">About</a>
                    <a href="#" class="me-3">Privacy</a>
                    <a href="#">Terms</a>
                </div>
            </div>
        </div>
    </div>
</footer>

<script>
document.getElementById('newsletterForm')?.addEventListener('submit', function(e) {
    e.preventDefault();
    const email = document.getElementById('newsletterEmail').value.trim();
    const msg = document.getElementById('newsletterMsg');

    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        msg.textContent = 'Please enter a valid email address.';
        msg.style.color = '#dc3545';
        return;
    }

    // Store in localStorage to avoid re-prompting same browser session
    localStorage.setItem('uninest_newsletter', email);
    this.innerHTML = `<p class="footer-newsletter-thanks"><i class="fa-solid fa-circle-check"></i> You're on the list!</p>`;
    msg.textContent = '';
});
</script>