<% layout("/layouts/boilerplate") %>
<link rel="stylesheet" href="/css/admin.css">

<div class="admin-wrapper">
    <div class="admin-sidebar">
        <div class="admin-brand">
            <i class="fa-solid fa-shield-halved"></i>
            <span>Admin Panel</span>
        </div>
        <nav class="admin-nav">
            <a href="/admin" class="admin-nav-item active">
                <i class="fa-solid fa-gauge"></i> Dashboard
            </a>
            <a href="/admin/listings" class="admin-nav-item">
                <i class="fa-solid fa-list-ul"></i> Listings
            </a>
            <a href="/admin/users" class="admin-nav-item">
                <i class="fa-solid fa-users"></i> Users
            </a>
            <a href="/listings" class="admin-nav-item">
                <i class="fa-solid fa-arrow-left"></i> Back to Site
            </a>
        </nav>
    </div>

    <div class="admin-content">
        <div class="admin-page-header">
            <h1>Dashboard</h1>
            <span class="admin-date"><%= new Date().toDateString() %></span>
        </div>

        <div class="admin-stats-grid">
            <div class="admin-stat-card">
                <div class="admin-stat-icon listings-icon">
                    <i class="fa-solid fa-house-user"></i>
                </div>
                <div>
                    <div class="admin-stat-num"><%= totalListings %></div>
                    <div class="admin-stat-lbl">Total Listings</div>
                </div>
            </div>
            <div class="admin-stat-card">
                <div class="admin-stat-icon users-icon">
                    <i class="fa-solid fa-users"></i>
                </div>
                <div>
                    <div class="admin-stat-num"><%= totalUsers %></div>
                    <div class="admin-stat-lbl">Total Users</div>
                </div>
            </div>
            <div class="admin-stat-card">
                <div class="admin-stat-icon bookings-icon">
                    <i class="fa-solid fa-calendar-check"></i>
                </div>
                <div>
                    <div class="admin-stat-num"><%= totalBookings %></div>
                    <div class="admin-stat-lbl">Total Bookings</div>
                </div>
            </div>
        </div>

        <div class="row g-4 mt-1">
            <div class="col-lg-6">
                <div class="admin-table-card">
                    <div class="admin-table-header">
                        <h5>Recent Listings</h5>
                        <a href="/admin/listings">View all →</a>
                    </div>
                    <table class="admin-table">
                        <thead><tr><th>Title</th><th>Location</th></tr></thead>
                        <tbody>
                            <% recentListings.forEach(l => { %>
                            <tr>
                                <td><a href="/listings/<%= l._id %>"><%= l.title %></a></td>
                                <td><%= l.location %></td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="admin-table-card">
                    <div class="admin-table-header">
                        <h5>Recent Users</h5>
                        <a href="/admin/users">View all →</a>
                    </div>
                    <table class="admin-table">
                        <thead><tr><th>Username</th><th>Email</th><th>Verified</th></tr></thead>
                        <tbody>
                            <% recentUsers.forEach(u => { %>
                            <tr>
                                <td><%= u.username %></td>
                                <td><%= u.email %></td>
                                <td>
                                    <span class="admin-badge <%= u.isVerified ? 'badge-success' : 'badge-warn' %>">
                                        <%= u.isVerified ? 'Yes' : 'No' %>
                                    </span>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>